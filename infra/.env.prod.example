# SciencesWiki — configuration de production (nœud Thor).
# Copier en `.env.prod` puis renseigner les VRAIS secrets. NE PAS COMMITER .env.prod.
#
#   cp .env.prod.example .env.prod && nano .env.prod
#   docker compose --env-file .env.prod up -d --build

# --- Domaine public (servi par nginx/Heimdall en HTTPS) -------------------
# Un seul domaine : front à la racine, API sous /api (cf. decision topologie).
PUBLIC_URL=https://scienceswiki.eu

# --- Secrets applicatifs (générer : `openssl rand -hex 32`) ---------------
APP_SECRET=__CHANGER_32_octets_hex__
WEB_APP_SECRET=__CHANGER_32_octets_hex__
# Passphrase de la clé privée JWT (générer : `openssl rand -hex 32`).
JWT_PASSPHRASE=__CHANGER_32_octets_hex__
# Jeton du endpoint RAG (/api/rag). OBLIGATOIRE : sans lui, l'API refuse le chat
# (fail-closed en prod). Généré : `openssl rand -hex 32`. Open WebUI l'utilise aussi.
RAG_API_TOKEN=__CHANGER_32_octets_hex__
# Secret JWT du hub Mercure (temps réel). NE PAS laisser vide (sinon jetons forgeables).
MERCURE_JWT_SECRET=__CHANGER_32_octets_hex__
# Jeton de contournement du mode maintenance (prévisualisation admin). Vide = aucun.
MAINTENANCE_BYPASS_TOKEN=

# --- Base de données PostgreSQL/pgvector ----------------------------------
POSTGRES_DB=scienceswiki
POSTGRES_USER=scienceswiki
POSTGRES_PASSWORD=__CHANGER_mot_de_passe_fort__

# --- Reverse proxy / sécurité ---------------------------------------------
# Symfony fait confiance aux X-Forwarded-* émis par le proxy. RESTREINDRE à l'IP de
# Heimdall (+ réseau Docker) : une plage trop large permet à un hôte LAN de forger
# X-Forwarded-For / usurper une IP. Recommandé : 192.168.1.195/32 + sous-réseau Docker.
TRUSTED_PROXIES=192.168.1.195/32,172.16.0.0/12
# Hôtes de confiance (anti Host spoofing). ⚠️ LAISSER VIDE est recommandé ici : nginx
# (Heimdall) valide déjà le Host via server_name (seule ingress). Si tu veux le contrôle
# applicatif EN PLUS, la regex DOIT inclure les noms internes Docker, sinon les appels
# web→api (Host « api ») tombent en 400 → site cassé. Ex. :
#   TRUSTED_HOSTS=^(scienceswiki\.eu|api|web|localhost|127\.0\.0\.1)$
TRUSTED_HOSTS=
# CORS : origines autorisées (apps Flutter web, etc.). Échapper les points.
CORS_ALLOW_ORIGIN=^https://scienceswiki\.eu$
# Origines autorisées pour le hub Mercure (défaut compose = PUBLIC_URL).
MERCURE_CORS_ORIGINS=https://scienceswiki.eu

# --- Ports publiés sur Thor (cibles du proxy Heimdall) --------------------
# IP de publication : l'IP LAN de Thor → api/web joignables SEULEMENT par Heimdall
# (jamais sur WAN/WiFi). Laisser vide/0.0.0.0 casserait l'isolation.
BIND_IP=192.168.1.36
API_PORT=8000
WEB_PORT=8090
# Adminer : accès direct = base en clair, DANGEREUX. Défaut 127.0.0.1 → accès par
# tunnel SSH uniquement (ssh -L 8091:127.0.0.1:8091 thor). Mettre l'IP de Thor pour
# un accès LAN (à restreindre au pare-feu).
ADMINER_BIND=127.0.0.1
# Open WebUI : PROXIFIÉ par Heimdall (chat.scienceswiki.eu) → doit écouter sur l'IP
# LAN de Thor, sinon Heimdall renvoie 504. Défaut = BIND_IP. ⚠️ L'accès direct sur
# :8092 contourne le SSO → restreindre au pare-feu (n'autoriser que 192.168.1.195).
OPENWEBUI_BIND=192.168.1.36

# --- Moisson --------------------------------------------------------------
HARVESTER_CONTACT_EMAIL=contact@scienceswiki.org

# --- IA locale (Marvin — 192.168.1.171) -----------------------------------
# Service d'embeddings ml/ déployé sur Marvin (cf. infra/marvin/).
ML_EMBED_URL=http://192.168.1.171:8001/embed
# LLM de rédaction RAG via Ollama (endpoint compatible OpenAI).
LLM_DRIVER=openai
LLM_BASE_URL=http://192.168.1.171:11434/v1
# Modèles réellement présents sur Marvin (ssh marvin 'ollama list') :
#   - qwen3.5:latest  (6.6 Go) — recommandé pour la rédaction RAG
#   - llama3.1:8b     (4.9 Go)
LLM_MODEL=qwen3.5:latest
# Jeton Bearer service-à-service (laisser vide si réseau privé de confiance).
LLM_API_TOKEN=
