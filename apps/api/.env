# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> app/harvester ###
# Adresse de contact transmise aux API (OpenAlex polite pool, Unpaywall) et au User-Agent.
HARVESTER_CONTACT_EMAIL=contact@scienceswiki.org
OPENALEX_BASE_URL=https://api.openalex.org
# NB : OPENALEX_API_KEY n'est PAS défini ici (sinon `composer dump-env` le
# figerait dans .env.local.php et masquerait le coffre de secrets). Défaut vide
# fourni via parameters: env(OPENALEX_API_KEY) dans config/services.yaml ; la
# valeur réelle vient du coffre Symfony (secret OPENALEX_API_KEY).
UNPAYWALL_BASE_URL=https://api.unpaywall.org/v2
ARXIV_OAI_URL=https://oaipmh.arxiv.org/oai
# IA (embeddings) : http = service ml/ auto-hébergé (prod) ; hashing = embedder local (dev/test).
EMBEDDING_DRIVER=http
# En prod (homelab), pointe vers la MACHINE IA DÉDIÉE (GPU) sur le réseau privé,
# ex. http://ia.homelab.lan:8001/embed (cf. spec §5.1).
ML_EMBED_URL=http://127.0.0.1:8001/embed
# Garde-fou anti-hallucination HHEM (service NLI dédié, cf. ml/hhem) — VIDE = désactivé
# (repli sur la vérification LLM). En prod : http://192.168.1.171:8002 (Marvin).
HHEM_URL=
###< app/harvester ###

###> app/llm ###
# LLM de rédaction RAG : openai = endpoint compatible OpenAI/Ollama ; stub = dev/tests.
LLM_DRIVER=openai
# En prod, base OpenAI/Ollama de la machine IA dédiée, ex. http://ia.homelab.lan:11434/v1
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3.6:27b
# Jeton Bearer optionnel (réseau privé homelab) — laissé vide en local.
LLM_API_TOKEN=
###< app/llm ###

###> app/rag-chat ###
# Jeton Bearer optionnel protégeant l'endpoint /api/rag/chat (Open WebUI).
# Vide = endpoint ouvert (réseau interne). Renseigner pour exiger Authorization.
RAG_API_TOKEN=
###< app/rag-chat ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# NE PAS mettre de vraie passphrase dans ce fichier VERSIONNÉ (il est aussi copié
# dans l'image). Valeur réelle fournie par l'environnement (.env.local en dev,
# variable JWT_PASSPHRASE du compose en prod). Défaut vide → keypair sans passphrase
# en dev local si non surchargé.
JWT_PASSPHRASE=
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
