{#
  Gabarit PDF commun (dompdf). En-tête et pied de page positionnés en points (pt),
  répétés sur chaque page (position:fixed). Les PDF concrets étendent ce gabarit et
  remplissent {% block content %}. Variable attendue : `date` (jj/mm/aaaa).
#}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        @page { margin: 102pt 42pt 60pt 42pt; }
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 11pt; line-height: 1.5; color: #1f2937; }

        /* En-tête répété (coordonnées absolues en pt) */
        .pdf-logo { position: fixed; left: 50pt; top: 26.5pt; width: 150pt; height: 37.9pt; }
        .pdf-slogan { position: fixed; top: 42pt; right: 42pt; width: 340pt; text-align: right;
            font-style: italic; color: #02356c; font-size: 10pt; }
        .pdf-sep { position: fixed; left: 42pt; right: 42pt; top: 79.5pt; border-top: 2px solid #019fb9; }

        /* Pied de page répété : filet, scienceswiki.eu + date à gauche, page courante à droite. */
        .pdf-footer { position: fixed; left: 42pt; right: 42pt; bottom: 30pt;
            border-top: 1px solid #cbd5e1; padding-top: 5pt; color: #64748b; font-size: 8.5pt; }
        .pdf-footer table { width: 100%; border: 0; border-collapse: collapse; }
        .pdf-footer .right { text-align: right; }
        .pdf-footer .page:after { content: "page " counter(page); }

        /* Bloc titre : titre du document › surtitre article (rubrique) › titre article (sujet) */
        h1 { font-size: 19pt; color: #02356c; margin: 0 0 10pt; }
        .surtitle { color: #019fb9; font-size: 9.5pt; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; margin: 0 0 2pt; }
        .article-title { font-size: 15pt; font-weight: bold; color: #02356c; margin: 0 0 16pt; line-height: 1.3; }

        /* Contenu */
        h2 { font-size: 13pt; color: #019fb9; margin: 14pt 0 4pt; page-break-after: avoid; }
        h3 { font-size: 11.5pt; color: #02356c; margin: 10pt 0 3pt; page-break-after: avoid; }
        p, li { page-break-inside: avoid; margin: 4pt 0; }
        ul, ol { margin: 4pt 0 4pt 10pt; }
        strong { color: #111827; }
        .biblio { margin-top: 18pt; border-top: 1px solid #ccc; padding-top: 8pt; }
        .ref { page-break-inside: avoid; margin: 6pt 0; font-size: 10pt; }
        .ref .url { color: #02356c; }
    </style>
</head>
<body>
    {% if pdf_assets.logo %}<img class="pdf-logo" src="{{ pdf_assets.logo }}" alt="SciencesWiki">{% endif %}
    <div class="pdf-slogan">le savoir scientifique, libre et vulgarisé</div>
    <div class="pdf-sep"></div>

    <footer class="pdf-footer">
        <table><tr>
            <td>scienceswiki.eu · {{ date }}</td>
            <td class="right page"></td>
        </tr></table>
    </footer>

    <main>
        {% block content %}{% endblock %}
    </main>
</body>
</html>
