{% extends 'pdf/_base.html.twig' %}

{% block content %}
    {% if rubric is defined and rubric %}<div class="surtitle">{{ rubric }}</div>{% endif %}
    <h1>{{ topic }}</h1>
    <div class="meta">Revue de littérature</div>

    <div class="review">{{ markdown|md }}</div>

    {% if sources is not empty %}
        <div class="biblio">
            <h2>Bibliographie</h2>
            {% for s in sources %}
                <div class="ref">
                    [{{ s.n }}] <strong>{{ s.title }}</strong>{% if s.authors is not empty %} — {{ s.authors|join(', ') }}{% endif %}{% if s.year %} ({{ s.year }}){% endif %}{% if s.venue %}. {{ s.venue }}{% endif %}.{% if s.citedByCount is not null %} {{ s.citedByCount }} citations.{% endif %}
                    {% if s.oaUrl %}<br><span class="url">{{ s.oaUrl }}</span>{% elseif s.doi %}<br><span class="url">https://doi.org/{{ s.doi }}</span>{% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
