{% extends 'base.html.twig' %}

{% block title %}{{ node.label }} — SciencesWiki{% endblock %}

{% block admin_context %}
    <a href="{{ path('admin_node', { slug: node.slug }) }}" style="color:#fcd34d">✏️ éditer / moissonner cette rubrique</a>
{% endblock %}

{% block body %}
    {% set crumbs = node.breadcrumb ?? [] %}
    {% if crumbs|length > 1 %}
        <p class="crumbs">
            {% set acc = '' %}
            {% for c in crumbs %}
                {% set acc = (acc == '' ) ? c.slug : acc ~ '/' ~ c.slug %}
                {% if not loop.last %}<a href="/{{ acc }}">{{ c.label }}</a> › {% else %}<span class="muted">{{ c.label }}</span>{% endif %}
            {% endfor %}
        </p>
    {% endif %}

    <h1>{{ node.label }}</h1>
    {% if node.description %}<p class="muted">{{ node.description }}</p>{% endif %}
    {% if corpusCount is defined and corpusCount > 0 %}
        <p><span class="pill">📚 {{ corpusCount|number_format(0, ',', ' ') }} publication(s) dans cette rubrique et ses sous-rubriques</span></p>
    {% endif %}
    {% if node.openalexUrl %}
        <p class="muted" style="font-size:.85rem">Concept de référence : <a href="{{ node.openalexUrl }}" rel="noopener" target="_blank">OpenAlex ↗</a></p>
    {% endif %}

    {% if node.children is not empty %}
        <h2>Sous-rubriques</h2>
        <div class="grid">
            {% for child in node.children %}
                <a class="card" href="/{{ path }}/{{ child.slug }}">{{ child.label }}</a>
            {% endfor %}
        </div>
    {% endif %}

    <h2>Questions &amp; réponses</h2>
    {% if answers is empty %}
        <p class="muted">Aucune question publiée pour cette rubrique. Posez la première ci-dessous.</p>
    {% else %}
        <ul class="qlist">
            {% for a in answers %}
                <li>
                    <a class="q-title" href="{{ path('answer', { id: a.id }) }}">{{ a.title }}</a>
                    <div class="qmeta">
                        <span class="pill author">✍️ {{ a.askerName }}</span>
                        {% if a.validationStatus == 'valide' %}
                            <span class="badge ok">✅ validé</span>
                        {% else %}
                            <span class="badge warn">⚠️ non relu</span>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    <div class="ask">
        <h2 style="margin-top:0">Poser une question sur « {{ node.label }} »</h2>
        <p class="muted" style="font-size:.85rem">Une réponse vulgarisée et sourcée sera rédigée par l'IA (gemma4), publiée avec la mention « non relu » en attendant la validation du comité.</p>
        <form id="ask-form" data-turbo="false" data-node="{{ node.slug }}">
            <label for="ask-name">Votre nom ou pseudonyme <span class="muted">(obligatoire)</span></label>
            <input type="text" id="ask-name" name="name" maxlength="120" required autocomplete="nickname">
            <label for="ask-q">Votre question</label>
            <textarea id="ask-q" name="question" maxlength="400" required placeholder="Ex. : Comment fonctionne… ?"></textarea>
            <button type="submit" id="ask-btn">Demander une réponse</button>
            <span id="ask-msg" class="muted" style="margin-left:.6rem"></span>
        </form>
        <p style="margin-top:.6rem">
            <button type="button" id="suggest-btn" style="background:#fff; color:var(--accent); border:1px solid var(--accent); border-radius:8px; padding:.55rem 1rem; font:inherit; font-weight:600; cursor:pointer">✨ Laisser l'IA proposer une question</button>
        </p>
        <div id="stream-out" hidden></div>
    </div>

    <script>
    (function () {
        var form = document.getElementById('ask-form');
        var btn = document.getElementById('ask-btn');
        var sbtn = document.getElementById('suggest-btn');
        var msg = document.getElementById('ask-msg');
        var out = document.getElementById('stream-out');
        var node = form.dataset.node;

        function render(raw) {
            out.innerHTML = raw
                .replace(/^##\s*TITRE\s*$/gmi, '')
                .replace(/^##\s*VULGARISATION\s*$/gmi, '')
                .replace(/^##\s*ACAD[EÉ]MIQUE\s*$/gmi, '<h4>Pour aller plus loin</h4>');
        }

        function setBusy(b) { btn.disabled = b; sbtn.disabled = b; }

        function startStream(streamUrl) {
            msg.innerHTML = '<span class="loader"></span> Rédaction en cours…';
            out.hidden = false; out.textContent = '';
            var acc = '';
            var es = new EventSource(streamUrl);
            es.onmessage = function (ev) {
                var data = JSON.parse(ev.data);
                if (data.delta) { acc += data.delta; render(acc); }
                if (data.nosource) { es.close(); setBusy(false); msg.textContent = ''; out.hidden = false; out.innerHTML = '<p class="muted">⚠️ ' + data.message + '</p>'; }
                if (data.error) { es.close(); setBusy(false); msg.textContent = data.error; }
                if (data.done) { es.close(); msg.innerHTML = '<span class="loader"></span> Réponse prête, redirection…'; window.location.href = '/q/' + data.answerId; }
            };
            es.onerror = function () { es.close(); setBusy(false); msg.textContent = 'Connexion interrompue.'; };
        }

        function post(url, body, loadingMsg) {
            setBusy(true);
            msg.innerHTML = '<span class="loader"></span> ' + loadingMsg;
            fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
                .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                .then(function (res) {
                    if (!res.ok) { throw new Error(res.d.error || 'Erreur'); }
                    startStream(res.d.stream);
                })
                .catch(function (err) { setBusy(false); msg.textContent = err.message; });
        }

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var name = document.getElementById('ask-name').value.trim();
            var question = document.getElementById('ask-q').value.trim();
            if (!name) { msg.textContent = 'Le nom ou pseudo est obligatoire.'; return; }
            if (question.length < 8) { msg.textContent = 'Votre question est trop courte.'; return; }
            post('/api/questions/ask', { name: name, question: question, node: node }, 'Envoi…');
        });

        sbtn.addEventListener('click', function () {
            post('/api/questions/suggest', { node: node }, 'L\'IA imagine une question…');
        });
    })();
    </script>
{% endblock %}
