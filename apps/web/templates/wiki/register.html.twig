{% extends 'base.html.twig' %}
{% block title %}Inscription — SciencesWiki{% endblock %}
{% block body %}
    <h1>Créer un compte</h1>
    <p class="muted">Espaces <strong>recherche</strong> et <strong>pédagogie</strong> : déclenchez vous-même les outils (évaluation méthodologique AXIS…), et pour les enseignants, gérez une classe. Ces comptes donnent accès aux <em>outils</em> — l'édition du contenu public reste réservée au comité.</p>
    {% for msg in app.flashes('error') %}<p class="badge warn">{{ msg }}</p>{% endfor %}

    <form class="ask" method="post" action="{{ path('register') }}" style="max-width:460px">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">

        <label for="r-role">Je suis…</label>
        <select id="r-role" name="role" required>
            <option value="researcher">Chercheur·e</option>
            <option value="teacher">Enseignant·e</option>
            <option value="student">Élève / Étudiant·e</option>
        </select>

        <label for="r-name">Nom (réel ou pseudo)</label>
        <input type="text" id="r-name" name="real_name" required autocomplete="name">

        <label for="r-email">E-mail</label>
        <input type="email" id="r-email" name="email" required autocomplete="email">

        <label for="r-pwd">Mot de passe <span class="muted" style="font-weight:normal">(8 caractères minimum)</span></label>
        <input type="password" id="r-pwd" name="password" required minlength="8" autocomplete="new-password">

        <button type="submit" style="margin-top:.8rem">Créer mon compte</button>
    </form>
    <p class="muted" style="font-size:.85rem; margin-top:1rem">Déjà inscrit·e ? <a href="{{ path('login') }}">Se connecter</a>.</p>
{% endblock %}
