{% extends 'base.html.twig' %}
{% block title %}Explorer — {{ node.label }}{% endblock %}
{% block body %}
    <style>
        .xp-wrap { display:grid; grid-template-columns:1fr 460px; gap:1.2rem; align-items:start; }
        @media (max-width:980px) { .xp-wrap { grid-template-columns:1fr; } .xp-detail { position:static !important; } }
        .xp-search { display:flex; gap:.5rem; flex-wrap:wrap; align-items:center; margin:.6rem 0 1rem; }
        .xp-search input[type=text] { flex:1; min-width:220px; padding:.6rem .8rem; border:1px solid #d1d5db; border-radius:9px; font:inherit; }
        .xp-toggle { display:inline-flex; align-items:center; gap:.4rem; font-size:.85rem; color:#374151; cursor:pointer; }
        table.xp { width:100%; border-collapse:collapse; font-size:.9rem; }
        table.xp th { text-align:left; padding:.45rem .4rem; border-bottom:2px solid var(--line); cursor:pointer; user-select:none; white-space:nowrap; }
        table.xp th:hover { color:var(--accent-dark); }
        table.xp th .arr { color:var(--accent); font-size:.75rem; }
        table.xp td { padding:.45rem .4rem; border-bottom:1px solid var(--line); vertical-align:top; }
        table.xp tr.row { cursor:pointer; }
        table.xp tr.row:hover { background:rgba(1,159,185,.07); }
        table.xp tr.row.sel { background:rgba(1,159,185,.14); }
        .xp-detail { position:sticky; top:1rem; border:1px solid var(--line); border-radius:12px; padding:1.1rem 1.2rem; max-height:calc(100vh - 2rem); overflow:auto; }
        .xp-detail h2 { margin:.2rem 0 .8rem; font-size:1.25rem; line-height:1.3; }
        .xp-detail .meta { font-size:.9rem; line-height:1.6; }
        .xp-detail .meta b { color:#111827; }
        .xp-detail .sep { border:0; border-top:1px solid var(--line); margin:.9rem 0; }
        .oa { background:#065f46; color:#fff; }
        .closed { background:#6b7280; color:#fff; }
        .ft { background:var(--accent); color:#fff; }
        .badge2 { display:inline-block; padding:.08rem .5rem; border-radius:999px; font-size:.72rem; font-weight:600; }
        .xp-empty { color:#6b7280; padding:2rem 1rem; text-align:center; }
        .xp-crumbs a { color:var(--accent-dark); }
    </style>

    <p class="crumbs muted"><a href="/{{ app.request.locale }}/{{ slug }}">← {{ node.label }}</a></p>
    <h1>Explorer les articles <span class="muted">— {{ node.label }}</span></h1>

    <div class="xp-search">
        <input type="text" id="xp-q" placeholder="Rechercher dans les articles de cette rubrique…" autocomplete="off">
        <label class="xp-toggle" title="Rapproche les mots de la même famille (run, running, runs…)">
            <input type="checkbox" id="xp-stem" checked> Racinisation (stemming)
        </label>
        <button id="xp-go" style="background:var(--accent); color:#fff; border:0; border-radius:9px; padding:.6rem 1.1rem; cursor:pointer; font:inherit">Rechercher</button>
        <span id="xp-count" class="muted" style="font-size:.85rem"></span>
    </div>

    <div class="xp-wrap">
        <div>
            <table class="xp">
                <thead>
                    <tr>
                        <th data-sort="titre">Titre <span class="arr" data-for="titre"></span></th>
                        <th data-sort="auteurs">Auteurs <span class="arr" data-for="auteurs"></span></th>
                        <th data-sort="annee">Année <span class="arr" data-for="annee"></span></th>
                        <th data-sort="revue">Revue <span class="arr" data-for="revue"></span></th>
                        <th>Accès</th>
                    </tr>
                </thead>
                <tbody id="xp-rows"></tbody>
            </table>
            <p id="xp-pager" style="margin-top:1rem; display:flex; gap:1rem; align-items:center"></p>
        </div>

        <aside class="xp-detail" id="xp-detail">
            <div class="xp-empty">Sélectionnez un article pour afficher ses informations.</div>
        </aside>
    </div>

    <script>
    (function () {
        var SLUG = {{ slug|json_encode|raw }};
        var state = { q: '', stemming: true, sort: '', dir: 'asc', page: 1, selected: null };
        var rows = document.getElementById('xp-rows');
        var pager = document.getElementById('xp-pager');
        var countEl = document.getElementById('xp-count');
        var detail = document.getElementById('xp-detail');

        function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : String(s)); return d.innerHTML; }

        function accessBadge(it) {
            var b = it.openAccess
                ? '<span class="badge2 oa" title="' + esc(it.oaStatus) + '">Open Access</span>'
                : '<span class="badge2 closed">Fermé</span>';
            if (it.fulltext) b += ' <span class="badge2 ft" title="Texte intégral indexé">texte intégral</span>';
            return b;
        }

        function load() {
            rows.innerHTML = '<tr><td colspan="5" class="muted" style="padding:1rem">Chargement…</td></tr>';
            var u = '/api/nodes/' + encodeURIComponent(SLUG) + '/articles?'
                + 'q=' + encodeURIComponent(state.q)
                + '&page=' + state.page
                + '&stemming=' + (state.stemming ? '1' : '0')
                + '&sort=' + encodeURIComponent(state.sort)
                + '&dir=' + state.dir;
            fetch(u).then(function (r) { return r.json(); }).then(function (d) {
                renderRows(d);
                renderPager(d);
                countEl.textContent = d.total.toLocaleString('fr-FR') + ' article(s)';
                updateArrows();
            });
        }

        function renderRows(d) {
            if (!d.items.length) { rows.innerHTML = '<tr><td colspan="5" class="xp-empty">Aucun article.</td></tr>'; return; }
            rows.innerHTML = '';
            d.items.forEach(function (it) {
                var tr = document.createElement('tr');
                tr.className = 'row' + (state.selected === it.id ? ' sel' : '');
                tr.innerHTML =
                    '<td><strong>' + esc(it.title || '(sans titre)') + '</strong></td>' +
                    '<td class="muted">' + esc((it.authors || '').slice(0, 60)) + '</td>' +
                    '<td class="muted">' + esc(it.year || '') + '</td>' +
                    '<td class="muted">' + esc((it.venue || '').slice(0, 30)) + '</td>' +
                    '<td>' + accessBadge(it) + '</td>';
                tr.addEventListener('click', function () { select(it.id, tr); });
                rows.appendChild(tr);
            });
        }

        function renderPager(d) {
            var h = '';
            if (d.page > 1) h += '<a href="#" data-pg="' + (d.page - 1) + '">← Précédent</a>';
            h += '<span class="muted">Page ' + d.page + ' / ' + Math.max(1, d.pages) + '</span>';
            if (d.page < d.pages) h += '<a href="#" data-pg="' + (d.page + 1) + '">Suivant →</a>';
            pager.innerHTML = h;
            pager.querySelectorAll('a[data-pg]').forEach(function (a) {
                a.addEventListener('click', function (e) { e.preventDefault(); state.page = +a.dataset.pg; load(); window.scrollTo(0, 0); });
            });
        }

        function updateArrows() {
            document.querySelectorAll('.arr').forEach(function (s) {
                s.textContent = (s.dataset.for === state.sort) ? (state.dir === 'asc' ? '▲' : '▼') : '';
            });
        }

        function select(id, tr) {
            state.selected = id;
            document.querySelectorAll('table.xp tr.row').forEach(function (r) { r.classList.remove('sel'); });
            if (tr) tr.classList.add('sel');
            detail.innerHTML = '<div class="xp-empty">Chargement…</div>';
            fetch('/api/articles/' + id).then(function (r) { return r.json(); }).then(renderDetail);
        }

        function renderDetail(a) {
            if (a.error) { detail.innerHTML = '<div class="xp-empty">' + esc(a.error) + '</div>'; return; }
            var m = '';
            if (a.retractionStatus && a.retractionStatus !== 'none') {
                m += '<p class="badge2" style="background:#dc2626;color:#fff;display:block;padding:.4rem .6rem">⚠️ ' +
                     (a.retractionStatus === 'retracted' ? 'Étude rétractée' : 'Expression de préoccupation') + '</p>';
            }
            m += '<h2>' + esc(a.title) + '</h2>';
            var links = [];
            if (a.landingPageUrl) links.push('<a href="' + esc(a.landingPageUrl) + '" target="_blank" rel="noopener">Page éditeur ↗</a>');
            if (a.oaUrl) links.push('<a href="' + esc(a.oaUrl) + '" target="_blank" rel="noopener">PDF / accès libre ↗</a>');
            if (a.doiUrl) links.push('<a href="' + esc(a.doiUrl) + '" target="_blank" rel="noopener">DOI ↗</a>');
            if (links.length) m += '<p>' + links.join(' · ') + '</p>';

            m += '<div class="meta">';
            if (a.year) m += '<b>Année :</b> ' + esc(a.year) + '<br>';
            if (a.type) m += '<b>Type :</b> ' + esc(a.type) + '<br>';
            if (a.language) m += '<b>Langue :</b> ' + esc(a.language) + '<br>';
            m += '<b>Accès :</b> ' + (a.openAccess ? 'Open Access (' + esc(a.oaStatus) + ')' : 'Fermé') + '<br>';
            if (a.fulltextAvailable) m += '<b>Texte intégral :</b> indexé pour la recherche<br>';
            m += '</div>';

            if (a.abstract) m += '<hr class="sep"><div class="meta"><b>Résumé</b><br>' + esc(a.abstract) + '</div>';

            m += '<hr class="sep"><div class="meta">';
            if (a.venue) m += '<b>Revue :</b> ' + esc(a.venue) + (a.issnL ? ' (ISSN ' + esc(a.issnL) + ')' : '') + '<br>';
            if (a.publisher) m += '<b>Éditeur :</b> ' + esc(a.publisher) + '<br>';
            if (a.authors && a.authors.length) m += '<b>Auteurs :</b> ' + a.authors.map(esc).join(', ') + '<br>';
            m += '</div>';

            if (a.hierarchy && a.hierarchy.length) {
                m += '<hr class="sep"><div class="meta xp-crumbs"><b>Classification</b><br>' +
                     a.hierarchy.map(function (h) { return '<a href="/{{ app.request.locale }}/' + esc(h.slug) + '">' + esc(h.label) + '</a>'; }).join(' › ') +
                     '</div>';
            }
            detail.innerHTML = m;
        }

        // Tri par en-tête
        document.querySelectorAll('th[data-sort]').forEach(function (th) {
            th.addEventListener('click', function () {
                var s = th.dataset.sort;
                if (state.sort === s) { state.dir = (state.dir === 'asc') ? 'desc' : 'asc'; }
                else { state.sort = s; state.dir = 'asc'; }
                state.page = 1; load();
            });
        });
        document.getElementById('xp-go').addEventListener('click', function () {
            state.q = document.getElementById('xp-q').value.trim();
            state.stemming = document.getElementById('xp-stem').checked;
            state.page = 1; load();
        });
        document.getElementById('xp-q').addEventListener('keydown', function (e) { if (e.key === 'Enter') document.getElementById('xp-go').click(); });

        load();
    })();
    </script>
{% endblock %}
