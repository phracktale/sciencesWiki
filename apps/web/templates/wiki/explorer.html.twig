{% extends 'base.html.twig' %}
{% block title %}Explorer — {{ node.label }}{% endblock %}
{% block body %}
    <style>
        .xp-wrap { display:grid; grid-template-columns:1fr 460px; gap:1.2rem; align-items:start; }
        @media (max-width:980px) { .xp-wrap { grid-template-columns:1fr; } .xp-detail { position:static !important; } }
        .xp-search { display:flex; gap:.5rem; flex-wrap:wrap; align-items:center; margin:.6rem 0 1rem; }
        .xp-search input[type=text] { flex:1; min-width:220px; padding:.6rem .8rem; border:1px solid #d1d5db; border-radius:9px; font:inherit; }
        .xp-toggle { display:inline-flex; align-items:center; gap:.4rem; font-size:.85rem; color:#374151; cursor:pointer; }
        table.xp { width:100%; border-collapse:collapse; font-size:.9rem; }
        table.xp th { text-align:left; padding:.45rem .4rem; border-bottom:2px solid var(--line); cursor:pointer; user-select:none; white-space:nowrap; }
        table.xp th:hover { color:var(--accent-dark); }
        table.xp th .arr { color:var(--accent); font-size:.75rem; }
        table.xp td { padding:.45rem .4rem; border-bottom:1px solid var(--line); vertical-align:top; }
        table.xp tr.row { cursor:pointer; }
        table.xp tr.row:hover { background:rgba(1,159,185,.07); }
        table.xp tr.row.sel { background:rgba(1,159,185,.14); }
        .xp-detail { position:sticky; top:1rem; border:1px solid var(--line); border-radius:12px; padding:1.1rem 1.2rem; max-height:calc(100vh - 2rem); overflow:auto; }
        .xp-detail h2 { margin:.2rem 0 .8rem; font-size:1.25rem; line-height:1.3; }
        .xp-detail .meta { font-size:.9rem; line-height:1.6; }
        .xp-detail .meta b { color:var(--ink); }
        .xp-detail .sep { border:0; border-top:1px solid var(--line); margin:.9rem 0; }
        .oa { background:#065f46; color:#fff; }
        .closed { background:#6b7280; color:#fff; }
        .ft { background:var(--accent); color:#fff; }
        .badge2 { display:inline-block; padding:.08rem .5rem; border-radius:999px; font-size:.72rem; font-weight:600; }
        .xp-empty { color:#6b7280; padding:2rem 1rem; text-align:center; }
        .xp-crumbs a { color:var(--accent-dark); }
        .axis-band { display:inline-block; padding:.1rem .55rem; border-radius:999px; font-size:.72rem; font-weight:700; color:#fff; }
        .axis-high { background:#065f46; } .axis-moderate { background:#b45309; }
        .axis-low { background:#b91c1c; } .axis-insufficient { background:#6b7280; }
        ul.axis-items { list-style:none; margin:.4rem 0 0; padding:0; font-size:.84rem; }
        ul.axis-items li { padding:.28rem 0; border-bottom:1px solid var(--line); display:flex; gap:.5rem; align-items:flex-start; }
        ul.axis-items .ax-ic { flex:0 0 1.1rem; text-align:center; font-weight:700; }
        .ax-yes { color:#065f46; } .ax-no { color:#b91c1c; } .ax-unclear { color:#9ca3af; }
        .axis-note { font-size:.74rem; color:#6b7280; margin-top:.5rem; font-style:italic; }
    </style>

    <p class="crumbs muted"><a href="/{{ app.request.locale }}/{{ slug }}">← {{ node.label }}</a></p>
    <h1>Explorer les articles <span class="muted">— {{ node.label }}</span></h1>

    <div class="xp-search">
        <input type="text" id="xp-q" placeholder="Rechercher dans les articles de cette rubrique…" autocomplete="off">
        <label class="xp-toggle" title="Rapproche les mots de la même famille (run, running, runs…)">
            <input type="checkbox" id="xp-stem" checked> Racinisation (stemming)
        </label>
        <label class="xp-toggle" title="Recherche par le SENS (sémantique + mots-clés) : trouve les articles pertinents même sans les mots exacts. Classe par pertinence.">
            <input type="checkbox" id="xp-sem"> Langage naturel
        </label>
        <div style="position:relative">
            <button type="button" id="xp-types-btn" style="background:#fff; border:1px solid #d1d5db; border-radius:9px; padding:.6rem .9rem; cursor:pointer; font:inherit">Types ▾</button>
            <div id="xp-types-panel" hidden style="position:absolute; z-index:20; top:calc(100% + 4px); left:0; background:#fff; border:1px solid #d1d5db; border-radius:9px; box-shadow:0 8px 24px rgba(0,0,0,.12); padding:.6rem .8rem; min-width:260px; max-height:340px; overflow:auto"></div>
        </div>
        <button id="xp-go" style="background:var(--accent); color:#fff; border:0; border-radius:9px; padding:.6rem 1.1rem; cursor:pointer; font:inherit">Rechercher</button>
        <span id="xp-count" class="muted" style="font-size:.85rem"></span>
    </div>

    <div class="xp-wrap">
        <div>
            <table class="xp">
                <thead>
                    <tr>
                        <th data-sort="titre">Titre <span class="arr" data-for="titre"></span></th>
                        <th data-sort="auteurs">Auteurs <span class="arr" data-for="auteurs"></span></th>
                        <th data-sort="annee">Année <span class="arr" data-for="annee"></span></th>
                        <th data-sort="revue">Revue <span class="arr" data-for="revue"></span></th>
                        <th>Accès</th>
                    </tr>
                </thead>
                <tbody id="xp-rows"></tbody>
            </table>
            <p id="xp-pager" style="margin-top:1rem; display:flex; gap:1rem; align-items:center"></p>
        </div>

        <aside class="xp-detail" id="xp-detail">
            <div class="xp-empty">Sélectionnez un article pour afficher ses informations.</div>
        </aside>
    </div>

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        var SLUG = {{ slug|json_js }};
        var state = { q: '', stemming: true, semantic: false, sort: '', dir: 'asc', page: 1, selected: null, types: [] };
        var rows = document.getElementById('xp-rows');
        var pager = document.getElementById('xp-pager');
        var countEl = document.getElementById('xp-count');
        var detail = document.getElementById('xp-detail');
        var typesPanel = document.getElementById('xp-types-panel');
        var typesBuilt = false;

        function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : String(s)); return d.innerHTML; }

        function accessBadge(it) {
            var b = it.openAccess
                ? '<span class="badge2 oa" title="' + esc(it.oaStatus) + '">Open Access</span>'
                : '<span class="badge2 closed">Fermé</span>';
            if (it.fulltext) b += ' <span class="badge2 ft" title="Texte intégral indexé">texte intégral</span>';
            return b;
        }

        function load() {
            rows.innerHTML = '<tr><td colspan="5" class="muted" style="padding:1rem">Chargement…</td></tr>';
            var u = '/api/nodes/' + encodeURIComponent(SLUG) + '/articles?'
                + 'q=' + encodeURIComponent(state.q)
                + '&page=' + state.page
                + '&stemming=' + (state.stemming ? '1' : '0')
                + '&semantic=' + (state.semantic ? '1' : '0')
                + '&sort=' + encodeURIComponent(state.sort)
                + '&dir=' + state.dir
                + state.types.map(function (t) { return '&types[]=' + encodeURIComponent(t); }).join('');
            fetch(u).then(function (r) { return r.json(); }).then(function (d) {
                if (!typesBuilt) buildTypes(d);
                renderRows(d);
                renderPager(d);
                countEl.textContent = d.total.toLocaleString('fr-FR') + (d.totalCapped ? '+' : '') + ' article(s)';
                updateArrows();
            });
        }

        // Construit le panneau de types (familles + cases) depuis la 1re réponse.
        // Par défaut : seuls les papiers primaires sont cochés (et remontés).
        function buildTypes(d) {
            typesBuilt = true;
            var families = d.families || {};
            var applied = d.appliedTypes || d.primaryTypes || [];
            var html = '';
            Object.keys(families).forEach(function (fam, i) {
                html += '<fieldset style="border:1px solid #eee; border-radius:8px; padding:.3rem .6rem; margin:.3rem 0">'
                    + '<legend style="font-size:.75rem; font-weight:700"><label style="cursor:pointer"><input type="checkbox" class="xp-grp-all" data-grp="xpg-' + i + '"> ' + esc(fam) + '</label></legend>';
                families[fam].forEach(function (t) {
                    var ck = applied.indexOf(t) !== -1 ? ' checked' : '';
                    html += '<label style="display:block; font-size:.82rem; cursor:pointer"><input type="checkbox" class="xp-type xpg-' + i + '" value="' + esc(t) + '"' + ck + '> ' + esc(t) + '</label>';
                });
                html += '</fieldset>';
            });
            html += '<div style="display:flex; gap:.5rem; margin-top:.4rem"><button type="button" id="xp-types-apply" style="background:var(--accent); color:#fff; border:0; border-radius:8px; padding:.4rem .9rem; cursor:pointer">Appliquer</button>'
                + '<button type="button" id="xp-types-primary" style="background:#fff; border:1px solid #d1d5db; border-radius:8px; padding:.4rem .9rem; cursor:pointer">Papiers primaires</button></div>';
            typesPanel.innerHTML = html;

            typesPanel.querySelectorAll('.xp-grp-all').forEach(function (master) {
                var boxes = typesPanel.querySelectorAll('input.' + master.getAttribute('data-grp'));
                function sync() { var all = boxes.length > 0; boxes.forEach(function (b) { if (!b.checked) all = false; }); master.checked = all; }
                master.addEventListener('change', function () { boxes.forEach(function (b) { b.checked = master.checked; }); });
                boxes.forEach(function (b) { b.addEventListener('change', sync); });
                sync();
            });
            document.getElementById('xp-types-apply').addEventListener('click', function () {
                state.types = Array.prototype.map.call(typesPanel.querySelectorAll('.xp-type:checked'), function (b) { return b.value; });
                state.page = 1; typesPanel.hidden = true; load();
            });
            document.getElementById('xp-types-primary').addEventListener('click', function () {
                state.types = []; state.page = 1; typesPanel.hidden = true; typesBuilt = false; load();
            });
        }

        // Badge compact de fiabilité AXIS (évaluation critique IA) affiché dans la liste.
        function axisBandBadge(band) {
            var map = {
                high: ['Fiabilité élevée', 'axis-high'],
                moderate: ['Fiabilité modérée', 'axis-moderate'],
                low: ['Fiabilité faible', 'axis-low'],
                insufficient: ['Éval. limitée', 'axis-insufficient']
            };
            var b = map[band];
            if (!b) return '';
            return ' <span class="axis-band ' + b[1] + '" title="Évaluation critique AXIS (générée par IA) — voir le détail de l\'article">' + b[0] + '</span>';
        }

        function renderRows(d) {
            if (!d.items.length) { rows.innerHTML = '<tr><td colspan="5" class="xp-empty">Aucun article.</td></tr>'; return; }
            rows.innerHTML = '';
            d.items.forEach(function (it) {
                var tr = document.createElement('tr');
                tr.className = 'row' + (state.selected === it.id ? ' sel' : '');
                tr.innerHTML =
                    '<td><strong>' + esc(it.title || '(sans titre)') + '</strong>' + axisBandBadge(it.axisBand) + '</td>' +
                    '<td class="muted">' + esc((it.authors || '').slice(0, 60)) + '</td>' +
                    '<td class="muted">' + esc(it.year || '') + '</td>' +
                    '<td class="muted">' + esc((it.venue || '').slice(0, 30)) + '</td>' +
                    '<td>' + accessBadge(it) + '</td>';
                tr.addEventListener('click', function () { select(it.id, tr); });
                rows.appendChild(tr);
            });
        }

        function renderPager(d) {
            var h = '';
            if (d.page > 1) h += '<a href="#" data-pg="' + (d.page - 1) + '">← Précédent</a>';
            h += '<span class="muted">Page ' + d.page + ' / ' + Math.max(1, d.pages) + '</span>';
            if (d.page < d.pages) h += '<a href="#" data-pg="' + (d.page + 1) + '">Suivant →</a>';
            pager.innerHTML = h;
            pager.querySelectorAll('a[data-pg]').forEach(function (a) {
                a.addEventListener('click', function (e) { e.preventDefault(); state.page = +a.dataset.pg; load(); window.scrollTo(0, 0); });
            });
        }

        function updateArrows() {
            document.querySelectorAll('.arr').forEach(function (s) {
                s.textContent = (s.dataset.for === state.sort) ? (state.dir === 'asc' ? '▲' : '▼') : '';
            });
        }

        function select(id, tr) {
            state.selected = id;
            document.querySelectorAll('table.xp tr.row').forEach(function (r) { r.classList.remove('sel'); });
            if (tr) tr.classList.add('sel');
            detail.innerHTML = '<div class="xp-empty">Chargement…</div>';
            fetch('/api/articles/' + id).then(function (r) { return r.json(); }).then(renderDetail);
        }

        // Rôles « outils » (chercheur/enseignant/élève) : ils voient LEURS analyses
        // déjà calculées, même non validées comité (avec marqueur). Le public, lui, ne
        // voit que les analyses validées (exposées par /api/articles).
        var XP_CAN_APPRAISE = {{ current_user.canUseAxis ? 'true' : 'false' }};
        function apprStatusNote(d) {
            if (!d.status) return '';
            return d.status === 'confirmed'
                ? ' <span class="muted" style="font-size:.72rem">· validé par le comité ✓</span>'
                : ' <span class="muted" style="font-size:.72rem">· analyse IA, non encore validée par le comité</span>';
        }
        function rob2Html(d) {
            var cols = { low: '#16a34a', some_concerns: '#f59e0b', high: '#dc2626', insufficient: '#64748b' };
            var h = '<hr class="sep"><div class="meta"><b>Risque de biais (RoB 2)</b>' + apprStatusNote(d) + '<br>';
            if (d.applicability === 'not_applicable') {
                h += '<span class="muted">' + esc(d.applicabilityLabel) + '</span><div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
                return h;
            }
            var oc = cols[d.overall] || '#f59e0b';
            h += '<span class="axis-band" style="background:' + oc + '22; color:' + oc + '">' + esc(d.overallLabel) + '</span>';
            if (d.summary) h += '<div style="margin-top:.4rem">' + esc(d.summary) + '</div>';
            if (d.domains && d.domains.length) {
                h += '<details style="margin-top:.4rem"><summary class="muted" style="cursor:pointer; font-size:.82rem">Voir les 5 domaines</summary><ul class="axis-items">';
                d.domains.forEach(function (dm) {
                    var c = cols[dm.judgement] || '#f59e0b';
                    h += '<li><span style="color:' + c + '; font-weight:600">' + esc(dm.judgementLabel) + '</span> — ' + esc(dm.title);
                    if (dm.quote) h += '<br><span class="muted" style="font-size:.76rem">« ' + esc(dm.quote) + ' »</span>';
                    h += '</li>';
                });
                h += '</ul></details>';
            }
            h += '<div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
            return h;
        }
        function amstar2Html(d) {
            var cols = { high: '#16a34a', moderate: '#f59e0b', low: '#f59e0b', critically_low: '#dc2626', insufficient: '#64748b' };
            var ic = { yes: ['✓', 'ax-yes'], partial_yes: ['~', 'ax-unclear'], no: ['✗', 'ax-no'] };
            var h = '<hr class="sep"><div class="meta"><b>Confiance dans la revue (AMSTAR-2)</b>' + apprStatusNote(d) + '<br>';
            if (d.applicability === 'not_applicable') {
                h += '<span class="muted">' + esc(d.applicabilityLabel) + '</span><div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
                return h;
            }
            var oc = cols[d.overall] || '#f59e0b';
            h += '<span class="axis-band" style="background:' + oc + '22; color:' + oc + '">' + esc(d.overallLabel) + '</span>';
            if (d.overall !== 'insufficient') h += ' <span class="muted" style="font-size:.78rem">' + d.criticalFlaws + ' défaut(s) critique(s)</span>';
            if (d.summary) h += '<div style="margin-top:.4rem">' + esc(d.summary) + '</div>';
            if (d.items && d.items.length) {
                h += '<details style="margin-top:.4rem"><summary class="muted" style="cursor:pointer; font-size:.82rem">Voir les 16 items</summary><ul class="axis-items">';
                d.items.forEach(function (it) {
                    var i = ic[it.answer] || ic.partial_yes;
                    h += '<li><span class="ax-ic ' + i[1] + '">' + i[0] + '</span><span>' + (it.critical ? '★ ' : '') + esc(it.question);
                    if (it.quote) h += '<br><span class="muted" style="font-size:.76rem">« ' + esc(it.quote) + ' »</span>';
                    h += '</span></li>';
                });
                h += '</ul></details>';
            }
            h += '<div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
            return h;
        }
        function mmatHtml(d) {
            var cols = { high: '#16a34a', moderate: '#f59e0b', low: '#dc2626', insufficient: '#64748b' };
            var ic = { yes: ['✓', 'ax-yes'], cant_tell: ['?', 'ax-unclear'], no: ['✗', 'ax-no'] };
            var h = '<hr class="sep"><div class="meta"><b>Qualité méthodologique (MMAT)</b>' + apprStatusNote(d) + '<br>';
            if (d.applicability !== 'applicable') {
                h += '<span class="muted">' + esc(d.applicabilityLabel) + '</span><div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
                return h;
            }
            var oc = cols[d.overall] || '#f59e0b';
            h += '<span class="axis-band" style="background:' + oc + '22; color:' + oc + '">' + esc(d.overallLabel) + '</span>';
            if (d.categoryLabel) h += ' <span class="muted" style="font-size:.78rem">' + esc(d.categoryLabel) + '</span>';
            if (d.overall !== 'insufficient') h += ' <span class="muted" style="font-size:.78rem">· ' + d.metCount + '/5 critères remplis</span>';
            if (d.summary) h += '<div style="margin-top:.4rem">' + esc(d.summary) + '</div>';
            var rows = (d.screening || []).concat(d.items || []);
            if (rows.length) {
                h += '<details style="margin-top:.4rem"><summary class="muted" style="cursor:pointer; font-size:.82rem">Voir le filtrage et les 5 critères</summary><ul class="axis-items">';
                rows.forEach(function (it) {
                    var i = ic[it.answer] || ic.cant_tell;
                    h += '<li><span class="ax-ic ' + i[1] + '">' + i[0] + '</span><span>' + esc(it.question);
                    if (it.quote) h += '<br><span class="muted" style="font-size:.76rem">« ' + esc(it.quote) + ' »</span>';
                    h += '</span></li>';
                });
                h += '</ul></details>';
            }
            h += '<div class="axis-note">' + esc(d.disclaimer) + '</div></div>';
            return h;
        }

        // Panneau « Évaluation méthodologique (AXIS) » de la fiche article.
        function axisHtml(ax) {
            var bands = { high: 'Fiabilité élevée', moderate: 'Fiabilité modérée', low: 'Fiabilité faible', insufficient: 'Information insuffisante' };
            var icons = { yes: ['✓', 'ax-yes'], no: ['✗', 'ax-no'], unclear: ['?', 'ax-unclear'] };
            var h = '<hr class="sep"><div class="meta"><b>Évaluation méthodologique (AXIS)</b>' + apprStatusNote(ax) + '<br>';
            // Verrou d'applicabilité : pour un design non transversal, AXIS est hors-sujet.
            if (ax.applicability === 'not_applicable') {
                h += '<span class="muted">' + esc(ax.applicabilityLabel) +
                     (ax.studyDesign ? ' — étude : ' + esc(ax.studyDesign) : '') + '</span>';
                h += '<div class="axis-note">' + esc(ax.disclaimer) + '</div></div>';
                return h;
            }
            if (ax.reliabilityBand) {
                h += '<span class="axis-band axis-' + esc(ax.reliabilityBand) + '">' + esc(bands[ax.reliabilityBand] || ax.reliabilityBand) + '</span> ';
                h += '<span class="muted" style="font-size:.78rem">' + ax.favorableCount + '/' + ax.assessableCount + ' critères favorables';
                if (ax.sourceScope === 'abstract') h += ' · résumé seul';
                h += '</span>';
            }
            if (ax.summary) h += '<div style="margin-top:.4rem">' + esc(ax.summary) + '</div>';
            if (ax.items && ax.items.length) {
                h += '<details style="margin-top:.4rem"><summary class="muted" style="cursor:pointer; font-size:.82rem">Voir les 20 critères</summary><ul class="axis-items">';
                ax.items.forEach(function (it) {
                    var ic = icons[it.answer] || icons.unclear;
                    var li = '<li><span class="ax-ic ' + ic[1] + '">' + ic[0] + '</span><span>' + esc(it.question);
                    if (it.quote) li += '<br><span class="muted" style="font-size:.76rem">« ' + esc(it.quote) + ' »</span>';
                    li += '</span></li>';
                    h += li;
                });
                h += '</ul></details>';
            }
            h += '<div class="axis-note">' + esc(ax.disclaimer) + '</div></div>';
            return h;
        }

        function renderDetail(a) {
            if (a.error) { detail.innerHTML = '<div class="xp-empty">' + esc(a.error) + '</div>'; return; }
            var m = '';
            if (a.retractionStatus && a.retractionStatus !== 'none') {
                m += '<p class="badge2" style="background:#dc2626;color:#fff;display:block;padding:.4rem .6rem">⚠️ ' +
                     (a.retractionStatus === 'retracted' ? 'Étude rétractée' : 'Expression de préoccupation') + '</p>';
            }
            m += '<h2>' + esc(a.title) + '</h2>';
            var links = [];
            if (a.landingPageUrl) links.push('<a href="' + esc(a.landingPageUrl) + '" target="_blank" rel="noopener">Page éditeur ↗</a>');
            if (a.oaUrl) links.push('<a href="' + esc(a.oaUrl) + '" target="_blank" rel="noopener">PDF / accès libre ↗</a>');
            if (a.doiUrl) links.push('<a href="' + esc(a.doiUrl) + '" target="_blank" rel="noopener">DOI ↗</a>');
            if (links.length) m += '<p>' + links.join(' · ') + '</p>';

            m += '<div class="meta">';
            if (a.year) m += '<b>Année :</b> ' + esc(a.year) + '<br>';
            if (a.type) m += '<b>Type :</b> ' + esc(a.type) + '<br>';
            if (a.language) m += '<b>Langue :</b> ' + esc(a.language) + '<br>';
            m += '<b>Accès :</b> ' + (a.openAccess ? 'Open Access (' + esc(a.oaStatus) + ')' : 'Fermé') + '<br>';
            if (a.fulltextAvailable) m += '<b>Texte intégral :</b> indexé pour la recherche<br>';
            m += '</div>';

            if (a.abstractFr) {
                m += '<hr class="sep"><div class="meta"><b>Résumé (traduit en français)</b><br>' + esc(a.abstractFr) + '</div>';
                if (a.abstract) m += '<details style="margin-top:.2rem"><summary class="muted" style="cursor:pointer; font-size:.82rem">Voir l\'original</summary><div class="meta">' + esc(a.abstract) + '</div></details>';
            } else if (a.abstract) {
                var trBtn = (a.language && a.language !== 'fr')
                    ? ' <button class="xp-tr" data-id="' + a.id + '" style="background:var(--accent); color:#fff; border:0; border-radius:7px; padding:.15rem .6rem; cursor:pointer; font-size:.78rem">🌐 Traduire en français</button>'
                    : '';
                m += '<hr class="sep"><div class="meta"><b>Résumé</b>' + trBtn + '<br>' + esc(a.abstract) + '</div>';
            }

            m += '<hr class="sep"><div class="meta">';
            if (a.venue) m += '<b>Revue :</b> ' + esc(a.venue) + (a.issnL ? ' (ISSN ' + esc(a.issnL) + ')' : '') + '<br>';
            if (a.publisher) m += '<b>Éditeur :</b> ' + esc(a.publisher) + '<br>';
            if (a.authors && a.authors.length) m += '<b>Auteurs :</b> ' + a.authors.map(esc).join(', ') + '<br>';
            m += '</div>';

            if (a.hierarchy && a.hierarchy.length) {
                m += '<hr class="sep"><div class="meta xp-crumbs"><b>Classification</b><br>' +
                     a.hierarchy.map(function (h) { return '<a href="/{{ app.request.locale }}/' + esc(h.slug) + '">' + esc(h.label) + '</a>'; }).join(' › ') +
                     '</div>';
            }
            // Public : AXIS validé comité (depuis /api/articles). Rôles outils : on
            // récupère ci-dessous TOUTES leurs analyses (AXIS/RoB 2/AMSTAR-2, tous statuts).
            if (a.axis && !XP_CAN_APPRAISE) m += axisHtml(a.axis);
            detail.innerHTML = m;
            if (XP_CAN_APPRAISE) {
                fetch('/{{ app.request.locale }}/etude/' + a.id + '/analyses')
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        var ap = d.appraisals || {};
                        var html = (ap.axis ? axisHtml(ap.axis) : '') + (ap.rob2 ? rob2Html(ap.rob2) : '') + (ap.amstar2 ? amstar2Html(ap.amstar2) : '') + (ap.mmat ? mmatHtml(ap.mmat) : '');
                        if (html) { var box = document.createElement('div'); box.innerHTML = html; detail.appendChild(box); }
                    })
                    .catch(function () {});
            }
            var trBtn = detail.querySelector('.xp-tr');
            if (trBtn) {
                trBtn.addEventListener('click', function () {
                    var id = trBtn.dataset.id;
                    trBtn.disabled = true; trBtn.textContent = '⏳ Traduction…';
                    fetch('/api/articles/' + id + '/translate', { method: 'POST' })
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            if (d.abstractFr) { select(id); } // recharge la fiche (traduction en cache)
                            else { trBtn.disabled = false; trBtn.textContent = '🌐 Réessayer'; }
                        })
                        .catch(function () { trBtn.disabled = false; trBtn.textContent = '🌐 Réessayer'; });
                });
            }
        }

        // Tri par en-tête
        document.querySelectorAll('th[data-sort]').forEach(function (th) {
            th.addEventListener('click', function () {
                var s = th.dataset.sort;
                if (state.sort === s) { state.dir = (state.dir === 'asc') ? 'desc' : 'asc'; }
                else { state.sort = s; state.dir = 'asc'; }
                // Un tri colonne reprend la main sur le classement sémantique.
                if (state.semantic) { state.semantic = false; document.getElementById('xp-sem').checked = false; }
                state.page = 1; load();
            });
        });
        document.getElementById('xp-go').addEventListener('click', function () {
            state.q = document.getElementById('xp-q').value.trim();
            state.stemming = document.getElementById('xp-stem').checked;
            state.semantic = document.getElementById('xp-sem').checked;
            // Le classement par pertinence sémantique est incompatible avec un tri colonne.
            if (state.semantic) { state.sort = ''; state.dir = 'asc'; }
            state.page = 1; load();
        });
        document.getElementById('xp-q').addEventListener('keydown', function (e) { if (e.key === 'Enter') document.getElementById('xp-go').click(); });

        // Ouverture/fermeture du panneau de types.
        document.getElementById('xp-types-btn').addEventListener('click', function (e) {
            e.stopPropagation(); typesPanel.hidden = !typesPanel.hidden;
        });
        typesPanel.addEventListener('click', function (e) { e.stopPropagation(); });
        document.addEventListener('click', function () { typesPanel.hidden = true; });

        load();
    })();
    </script>
{% endblock %}
