{% extends 'base.html.twig' %}
{% block title %}Connexion — SciencesWiki{% endblock %}
{% block body %}
    <h1>Connexion</h1>
    <p class="muted">Connectez-vous à votre compte SciencesWiki. Vos accès dépendent de vos rôles (chercheur, rédacteur, comité, administration).</p>
    {% for msg in app.flashes('error') %}<p class="badge warn">{{ msg }}</p>{% endfor %}

    <form class="ask" method="post" action="{{ path('login') }}" style="max-width:420px">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <input type="hidden" name="back" value="{{ back }}">
        <label for="l-email">E-mail</label>
        <input type="email" id="l-email" name="email" required autocomplete="username">
        <label for="l-pwd">Mot de passe</label>
        <input type="password" id="l-pwd" name="password" required autocomplete="current-password">
        <button type="submit" style="margin-top:.8rem">Se connecter</button>
    </form>
    <p class="muted" style="font-size:.85rem; margin-top:1rem">Chercheur·e, enseignant·e ou élève ? <a href="{{ path('register') }}">Créez votre compte</a>. Pour rejoindre le comité/la rédaction, voir <a href="{{ path('project') }}">« Le projet »</a>.</p>
{% endblock %}
