{% extends 'base.html.twig' %}
{% block title %}Évaluation critique — SciencesWiki{% endblock %}
{% block body %}
    <h1>Évaluation critique des études 🔬</h1>
    <p class="muted">Cherchez une étude par <strong>titre, mots-clés ou DOI</strong>. Selon le devis détecté, l'IA propose l'outil adapté : <strong>AXIS</strong> (études transversales), <strong>RoB 2</strong> (essais randomisés) ou <strong>AMSTAR-2</strong> (revues systématiques). <strong>Ce ne sont pas des notes</strong> — des signaux pour vous aider à juger, jamais un verdict.</p>
    <p style="font-size:.9rem"><a href="{{ path('my_studies') }}">📄 Mes études déposées →</a></p>

    <form class="ask" method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="max-width:560px; display:flex; gap:.5rem; align-items:flex-end; flex-wrap:wrap">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <div style="flex:1; min-width:280px">
            <label for="a-q">Titre, mots-clés ou DOI de l'étude</label>
            <input type="text" id="a-q" name="query" required value="{{ query }}" placeholder="ex. : essai randomisé metformine, ou 10.1136/bmj-…">
        </div>
        <button type="submit">Rechercher</button>
    </form>

    {% if error %}<p class="badge warn" style="margin-top:1rem">{{ error }}</p>{% endif %}

    <details style="margin-top:1rem; max-width:660px"{% if error %} open{% endif %}>
        <summary style="cursor:pointer; color:var(--accent); font-weight:600">📎 L'étude n'est pas dans le corpus ? Déposez son PDF pour l'évaluer</summary>
        <form method="post" action="{{ path('axis_deposit') }}" enctype="multipart/form-data" data-turbo="false" class="card" style="margin-top:.6rem; display:grid; gap:.55rem">
            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
            <div><label for="d-title">Titre de l'étude *</label><input type="text" id="d-title" name="title" required></div>
            <div style="display:flex; gap:.5rem; flex-wrap:wrap">
                <div style="flex:1; min-width:180px"><label for="d-doi">DOI (optionnel)</label><input type="text" id="d-doi" name="doi" placeholder="10.xxxx/…"></div>
                <div style="width:110px"><label for="d-year">Année</label><input type="text" id="d-year" name="year" inputmode="numeric" pattern="[0-9]{4}"></div>
            </div>
            <div><label for="d-venue">Revue (optionnel)</label><input type="text" id="d-venue" name="venue"></div>
            <div><label for="d-abstract">Résumé (optionnel — améliore la détection du type d'étude)</label><textarea id="d-abstract" name="abstract" rows="3"></textarea></div>
            <div><label for="d-tool">Outil d'évaluation</label>
                <select id="d-tool" name="tool">
                    <option value="axis">AXIS (étude transversale)</option>
                    <option value="rob2">RoB 2 (essai randomisé)</option>
                    <option value="amstar2">AMSTAR-2 (revue systématique)</option>
                    <option value="mmat">MMAT (étude empirique / mixte)</option>
                </select>
            </div>
            <div><label for="d-pdf">PDF de l'étude * <span class="muted">(avec couche texte — pas un scan image)</span></label><input type="file" id="d-pdf" name="pdf" accept="application/pdf,.pdf" required></div>
            <button type="submit">Déposer et évaluer</button>
            <p class="muted" style="font-size:.78rem; margin:0">Votre étude reste <strong>privée</strong> (visible de vous seul). Après l'évaluation, vous pourrez proposer son ajout au corpus (soumis à validation du comité).</p>
        </form>
    </details>

    {% if candidates is not empty and candidates is not null %}
        <h2 style="margin-top:1.4rem">Choisissez l'étude à évaluer</h2>
        <ul style="list-style:none; padding:0">
            {% for c in candidates %}
                <li class="card" style="margin:.5rem 0; display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap">
                    <div style="flex:1; min-width:260px">
                        <strong>{{ c.title }}</strong>
                        <div class="muted" style="font-size:.85rem">
                            {% if c.leadAuthor %}{{ c.leadAuthor }}{% if c.authors|length > 1 %} et al.{% endif %} · {% endif %}
                            {% if c.year %}{{ c.year }} · {% endif %}{{ c.venue }}
                            {% if c.citedByCount %} · 📈 {{ c.citedByCount }} cit.{% endif %}
                        </div>
                        {% if c.id %}
                            <div style="margin-top:.2rem">
                                <button type="button" class="js-abs-toggle" data-id="{{ c.id }}" style="background:none; border:0; color:var(--accent); cursor:pointer; font-size:.78rem; padding:0">▸ Résumé</button>
                                <div class="abs-detail" hidden style="margin-top:.3rem; font-size:.85rem; max-width:640px"></div>
                            </div>
                        {% endif %}
                    </div>
                    {% if not c.doi %}
                        <span class="muted" style="font-size:.8rem">DOI manquant — non évaluable</span>
                    {% else %}
                        {% set st = toolStates[c.doi]|default(null) %}
                        {% set recoAxis = st and st.classified and st.axisApplicable %}
                        {% set recoRob2 = st and st.classified and st.rob2Applicable %}
                        {% set recoAmstar2 = st and st.classified and st.amstar2Applicable %}
                        {% set recoMmat = st and st.classified and st.mmatApplicable %}
                        <div style="text-align:right; min-width:220px">
                            {% if st is null or not st.classified %}
                                <div class="muted" style="font-size:.74rem; margin-bottom:.3rem">🔎 détection du type d'étude…</div>
                            {% else %}
                                <div class="muted" style="font-size:.74rem">Devis probable : <strong>{{ st.designLabel }}</strong></div>
                                {% for t in st.tools %}{% if not t.implemented %}<span class="badge" style="font-size:.7rem; background:#eef2ff; color:#3730a3; margin:.1rem 0 0 .2rem">{{ t.name }} · à venir</span>{% endif %}{% endfor %}
                            {% endif %}
                            <div style="margin-top:.35rem; display:flex; gap:.3rem; flex-wrap:wrap; justify-content:flex-end">
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="axis">
                                    <button type="submit"{% if not recoAxis %} style="background:#e2e8f0; color:#475569"{% endif %}>AXIS{% if recoAxis %} ✓{% endif %}</button>
                                </form>
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="rob2">
                                    <button type="submit"{% if not recoRob2 %} style="background:#e2e8f0; color:#475569"{% endif %}>RoB 2{% if recoRob2 %} ✓{% endif %}</button>
                                </form>
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="amstar2">
                                    <button type="submit"{% if not recoAmstar2 %} style="background:#e2e8f0; color:#475569"{% endif %}>AMSTAR-2{% if recoAmstar2 %} ✓{% endif %}</button>
                                </form>
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="mmat">
                                    <button type="submit"{% if not recoMmat %} style="background:#e2e8f0; color:#475569"{% endif %}>MMAT{% if recoMmat %} ✓{% endif %}</button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
        <p class="muted" style="font-size:.82rem">✓ = outil recommandé pour le devis détecté. L'analyse IA (~1 min) se lance <strong>en arrière-plan</strong> et le résultat <strong>s'affiche automatiquement</strong>.</p>
    {% endif %}

    {% if pending %}
        {% set toolName = {'rob2': 'RoB 2', 'amstar2': 'AMSTAR-2', 'mmat': 'MMAT'}[pending.tool]|default('AXIS') %}
        <article class="card" id="axis-pending" data-doi="{{ pending.doi }}" data-id="{{ pending.id|default('') }}" data-tool="{{ pending.tool }}" data-status-url="{{ path('axis_status') }}" style="margin-top:1.2rem">
            <h2 style="margin-top:0">⏳ Évaluation {{ toolName }} en cours…</h2>
            {% if pending.publication %}<p><strong>{{ pending.publication.title }}</strong></p>{% endif %}
            <p class="muted">L'IA applique la grille {{ toolName }} (résumé + texte intégral) sur un serveur dédié. Cela prend <strong>~1 minute</strong>. Cette page se met à jour <strong>automatiquement</strong> ; vous pouvez aussi fermer et revenir plus tard : le résultat sera conservé.</p>
            <p class="muted" id="axis-pending-msg">🔄 Vérification automatique du résultat…</p>
            <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" id="axis-pending-form" style="margin-top:.4rem">
                <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                <input type="hidden" name="doi" value="{{ pending.doi }}">
                <input type="hidden" name="id" value="{{ pending.id|default('') }}">
                <input type="hidden" name="private" value="{{ privateStudy ? '1' : '' }}">
                <input type="hidden" name="tool" value="{{ pending.tool }}">
                <button type="submit">Rafraîchir maintenant</button>
            </form>
        </article>
        <script nonce="{{ csp_nonce.value }}">
        (function () {
            var box = document.getElementById('axis-pending');
            if (!box) { return; }
            var pid = box.getAttribute('data-id');
            var q = pid ? ('&id=' + encodeURIComponent(pid)) : ('&doi=' + encodeURIComponent(box.getAttribute('data-doi')));
            var url = box.getAttribute('data-status-url') + '?tool=' + encodeURIComponent(box.getAttribute('data-tool')) + q;
            var msg = document.getElementById('axis-pending-msg');
            var form = document.getElementById('axis-pending-form');
            var tries = 0;
            var timer = setInterval(function () {
                tries++;
                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (d.status === 'ready') { clearInterval(timer); form.submit(); }
                        else if (d.status === 'none') { clearInterval(timer); if (msg) { msg.textContent = '⚠️ Évaluation terminée sans résultat : cette étude n’est pas exploitable (ni résumé ni texte intégral accessible).'; } }
                        else if (tries > 75) { clearInterval(timer); if (msg) { msg.textContent = 'L’évaluation prend plus de temps que prévu. Cliquez « Rafraîchir maintenant ».'; } }
                    })
                    .catch(function () {});
            }, 4000);
        })();
        </script>
    {% endif %}

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        document.querySelectorAll('form.js-axis-run').forEach(function (f) {
            f.addEventListener('submit', function () {
                var b = f.querySelector('button');
                if (b) { b.disabled = true; b.textContent = '⏳…'; }
            });
        });
    })();
    </script>

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        function esc(s) { var d = document.createElement('div'); d.textContent = (s == null ? '' : s); return d.innerHTML; }
        function absHtml(a) {
            if (!a || a.error) { return '<span class="muted">Détail indisponible.</span>'; }
            var h = '';
            if (a.retractionStatus && a.retractionStatus !== 'none') {
                h += '<div style="color:#b91c1c; font-weight:600; margin:.1rem 0">⚠️ Article rétracté</div>';
            }
            var links = [];
            if (a.oaUrl) { links.push('<a href="' + esc(a.oaUrl) + '" target="_blank" rel="noopener">PDF / accès libre ↗</a>'); }
            if (a.landingPageUrl) { links.push('<a href="' + esc(a.landingPageUrl) + '" target="_blank" rel="noopener">Page éditeur ↗</a>'); }
            if (a.doiUrl) { links.push('<a href="' + esc(a.doiUrl) + '" target="_blank" rel="noopener">DOI ↗</a>'); }
            if (links.length) { h += '<div style="margin:.1rem 0">' + links.join(' · ') + '</div>'; }
            var meta = [];
            if (a.type) { meta.push(esc(a.type)); }
            meta.push(a.openAccess ? ('Open Access' + (a.oaStatus ? ' (' + esc(a.oaStatus) + ')' : '')) : 'Accès fermé');
            if (a.fulltextAvailable) { meta.push('texte intégral indexé'); }
            h += '<div class="muted" style="font-size:.78rem">' + meta.join(' · ') + '</div>';
            var abstract = a.abstractFr || a.abstract;
            h += abstract
                ? '<p style="margin:.3rem 0 0">' + esc(abstract) + '</p>'
                : '<p class="muted" style="margin:.3rem 0 0">(pas de résumé disponible)</p>';
            return h;
        }
        document.querySelectorAll('.js-abs-toggle').forEach(function (btn) {
            var box = btn.nextElementSibling;
            if (!box) { return; }
            btn.addEventListener('click', function () {
                if (!box.dataset.loaded) {
                    box.dataset.loaded = '1';
                    box.hidden = false; box.innerHTML = '<span class="muted">Chargement…</span>'; btn.textContent = '▾ Résumé';
                    fetch('/api/articles/' + encodeURIComponent(btn.dataset.id))
                        .then(function (r) { return r.json(); })
                        .then(function (a) { box.innerHTML = absHtml(a); })
                        .catch(function () { box.innerHTML = '<span class="muted">Détail indisponible.</span>'; });
                } else {
                    box.hidden = !box.hidden;
                    btn.textContent = (box.hidden ? '▸' : '▾') + ' Résumé';
                }
            });
        });
    })();
    </script>

    {% if result %}
        <article class="card" style="margin-top:1.2rem">
            <h2 style="margin-top:0">{{ result.publication.title }}</h2>
            <p class="muted" style="font-size:.85rem">
                {% if result.publication.year %}{{ result.publication.year }} · {% endif %}
                {% if result.publication.doi %}<a href="https://doi.org/{{ result.publication.doi }}" target="_blank" rel="noopener">{{ result.publication.doi }}</a>{% endif %}
            </p>

            {% if result.tool == 'rob2' %}
                {% set apColor = result.applicability == 'applicable' ? '#16a34a' : (result.applicability == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">RoB 2</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>

                {% if result.applicability == 'not_applicable' %}
                    <p class="muted">RoB 2 n'a été validé que pour les essais randomisés : la grille n'est <strong>pas</strong> appliquée à ce design (aucun résultat trompeur).</p>
                {% else %}
                    {% set ovColor = result.overall == 'low' ? '#16a34a' : (result.overall == 'high' ? '#dc2626' : '#f59e0b') %}
                    <p>Risque de biais global : <span class="badge" style="background:{{ ovColor }}22; color:{{ ovColor }}; font-weight:700">{{ result.overallLabel }}</span>
                       <span class="muted" style="margin-left:.4rem">(source : {{ result.sourceScope == 'abstract+fulltext' ? 'résumé + texte intégral' : 'résumé seul' }})</span></p>

                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}

                    <ul style="list-style:none; padding:0; margin:.6rem 0">
                        {% for d in result.domains %}
                            {% set dc = d.judgement == 'low' ? '#16a34a' : (d.judgement == 'high' ? '#dc2626' : '#f59e0b') %}
                            <li style="padding:.5rem 0; border-bottom:1px solid var(--line)">
                                <strong>{{ d.title }}</strong> — <span style="color:{{ dc }}; font-weight:600">{{ d.judgementLabel }}</span>
                                {% if d.rationale %}<div class="muted" style="font-size:.85rem; margin-top:.15rem">{{ d.rationale }}</div>{% endif %}
                                {% if d.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ d.quote }} »</blockquote>{% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            {% else %}{% if result.tool == 'amstar2' %}
                {% set apColor = result.applicability == 'applicable' ? '#16a34a' : (result.applicability == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">AMSTAR-2</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>
                {% if result.applicability == 'not_applicable' %}
                    <p class="muted">AMSTAR-2 ne s'applique qu'aux revues systématiques : la grille n'est <strong>pas</strong> appliquée à ce design.</p>
                {% else %}
                    {% set ovColor = result.overall == 'high' ? '#16a34a' : (result.overall == 'critically_low' ? '#dc2626' : (result.overall == 'insufficient' ? '#64748b' : '#f59e0b')) %}
                    <p>Niveau de confiance : <span class="badge" style="background:{{ ovColor }}22; color:{{ ovColor }}; font-weight:700">{{ result.overallLabel }}</span></p>
                    {% if result.overall == 'insufficient' %}
                        <p class="muted">AMSTAR-2 nécessite le <strong>texte intégral</strong> pour une évaluation fiable ; ici, seul le <strong>résumé</strong> est disponible. Les 16 items ci-dessous sont donc <strong>indicatifs</strong> (un élément non mentionné dans le résumé apparaît comme « non »).</p>
                    {% else %}
                        <p class="muted">{{ result.criticalFlaws }} défaut(s) critique(s), {{ result.weaknesses }} réserve(s) · source : résumé + texte intégral.</p>
                    {% endif %}
                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}
                    <details style="margin-top:.8rem">
                        <summary style="cursor:pointer; font-weight:600">Les 16 items en détail (★ = domaine critique)</summary>
                        <ul style="list-style:none; padding:0; margin:.6rem 0">
                            {% for it in result.items %}
                                {% set icon = it.answer == 'yes' ? '✅' : (it.answer == 'partial_yes' ? '🟡' : '⚠️') %}
                                <li style="padding:.4rem 0; border-bottom:1px solid var(--line)">
                                    {{ icon }} {% if it.critical %}<span style="color:#dc2626" title="domaine critique">★</span> {% endif %}<strong>{{ it.question }}</strong>
                                    <span class="muted">— {{ it.answerLabel }}</span>
                                    {% if it.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ it.quote }} »</blockquote>{% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </details>
                {% endif %}
            {% else %}{% if result.tool == 'mmat' %}
                {% set apColor = result.applicability == 'applicable' ? '#16a34a' : (result.applicability == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">MMAT</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.category %}<span class="muted" style="margin-left:.5rem">catégorie : <strong>{{ result.categoryLabel }}</strong></span>{% endif %}
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>
                {% if result.applicability != 'applicable' %}
                    <p class="muted">MMAT ne s'applique qu'aux études <strong>empiriques</strong> (les revues systématiques relèvent d'AMSTAR-2) : la grille n'est <strong>pas</strong> appliquée ici.</p>
                {% else %}
                    {% set ovColor = result.overall == 'high' ? '#16a34a' : (result.overall == 'low' ? '#dc2626' : (result.overall == 'insufficient' ? '#64748b' : '#f59e0b')) %}
                    <p>Qualité indicative : <span class="badge" style="background:{{ ovColor }}22; color:{{ ovColor }}; font-weight:700">{{ result.overallLabel }}</span>
                       <span class="muted" style="margin-left:.4rem">— filtrage {{ result.screeningPassed ? 'satisfait ✅' : 'non satisfait ⚠️' }}</span></p>
                    {% if result.overall == 'insufficient' %}
                        <p class="muted">MMAT nécessite le <strong>texte intégral</strong> pour une évaluation fiable ; ici, seul le <strong>résumé</strong> est disponible. Les critères ci-dessous sont donc <strong>indicatifs</strong>.</p>
                    {% else %}
                        <p class="muted">{{ result.metCount }}/5 critères remplis · source : résumé + texte intégral. <em>MMAT déconseille un score global : ce repère est purement indicatif.</em></p>
                    {% endif %}
                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}
                    {% if result.screening %}
                        <details style="margin-top:.8rem">
                            <summary style="cursor:pointer; font-weight:600">Questions de filtrage</summary>
                            <ul style="list-style:none; padding:0; margin:.6rem 0">
                                {% for it in result.screening %}
                                    {% set icon = it.answer == 'yes' ? '✅' : (it.answer == 'cant_tell' ? '❔' : '⚠️') %}
                                    <li style="padding:.4rem 0; border-bottom:1px solid var(--line)">
                                        {{ icon }} <strong>{{ it.question }}</strong> <span class="muted">— {{ it.answerLabel }}</span>
                                        {% if it.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ it.quote }} »</blockquote>{% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </details>
                    {% endif %}
                    <details style="margin-top:.4rem" open>
                        <summary style="cursor:pointer; font-weight:600">Les 5 critères de la catégorie en détail</summary>
                        <ul style="list-style:none; padding:0; margin:.6rem 0">
                            {% for it in result.items %}
                                {% set icon = it.answer == 'yes' ? '✅' : (it.answer == 'cant_tell' ? '❔' : '⚠️') %}
                                <li style="padding:.4rem 0; border-bottom:1px solid var(--line)">
                                    {{ icon }} <strong>{{ it.question }}</strong> <span class="muted">— {{ it.answerLabel }}</span>
                                    {% if it.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ it.quote }} »</blockquote>{% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </details>
                {% endif %}
            {% else %}
                {% set ap = result.applicability %}
                {% set apColor = ap == 'applicable' ? '#16a34a' : (ap == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">AXIS</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>

                {% if ap == 'not_applicable' %}
                    <p class="muted">AXIS n'a été validé que pour les études transversales : la grille n'est <strong>pas</strong> appliquée à ce design (aucun résultat trompeur).</p>
                {% else %}
                    {% set band = result.reliabilityBand %}
                    {% set bandLabel = {'high':'élevée','moderate':'modérée','low':'faible','insufficient':'insuffisante (texte trop limité)'} %}
                    <p>Fiabilité indicative : <strong>{{ bandLabel[band] ?? band }}</strong>
                       — {{ result.favorableCount }}/{{ result.assessableCount }} critères favorables
                       <span class="muted">(source : {{ result.sourceScope == 'abstract+fulltext' ? 'résumé + texte intégral' : 'résumé seul' }})</span></p>

                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}

                    <details style="margin-top:.8rem">
                        <summary style="cursor:pointer; font-weight:600">Les 20 critères en détail</summary>
                        <ul style="list-style:none; padding:0; margin:.6rem 0">
                            {% for it in result.items %}
                                {% set icon = it.favorable ? '✅' : (it.answer == 'unclear' ? '❔' : '⚠️') %}
                                <li style="padding:.4rem 0; border-bottom:1px solid var(--line)">
                                    {{ icon }} <strong>{{ it.question }}</strong>
                                    <span class="muted">— {{ it.answerLabel }}</span>
                                    {% if it.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ it.quote }} »</blockquote>{% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </details>
                {% endif %}
            {% endif %}{% endif %}{% endif %}

            <p class="muted" style="font-size:.78rem; margin-top:1rem; border-top:1px dashed var(--line); padding-top:.6rem">{{ result.disclaimer }}</p>
        </article>
    {% endif %}

    {% if privateStudy %}
        <article class="card" id="corpus-offer" data-id="{{ privateStudy.id }}" data-url="{{ path('axis_corpus') }}" data-csrf="{{ admin_csrf.token }}" style="margin-top:1rem; background:#f0f9ff; border-color:#38bdf8">
            <p style="margin:0 0 .5rem"><strong>📥 Cette étude n'est pas dans le corpus.</strong> Souhaitez-vous la proposer pour que les autres en profitent&nbsp;? Un membre du comité la validera avant l'ajout ; elle sera alors indexée (recherche) et placée dans l'arborescence.</p>
            <button type="button" id="corpus-btn">Proposer l'ajout au corpus</button>
            <span id="corpus-msg" class="muted" style="margin-left:.6rem"></span>
        </article>
        <script nonce="{{ csp_nonce.value }}">
        (function () {
            var box = document.getElementById('corpus-offer'); if (!box) { return; }
            var btn = document.getElementById('corpus-btn'), msg = document.getElementById('corpus-msg');
            btn.addEventListener('click', function () {
                btn.disabled = true; btn.textContent = '⏳…';
                var body = new URLSearchParams(); body.set('id', box.dataset.id); body.set('_csrf', box.dataset.csrf);
                fetch(box.dataset.url, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': box.dataset.csrf }, body: body.toString(), credentials: 'same-origin' })
                    .then(function (r) { return r.json(); })
                    .then(function (d) { btn.style.display = 'none'; if (msg) { msg.textContent = d.message || (d.ok ? 'Proposition envoyée.' : 'Échec.'); } })
                    .catch(function () { btn.disabled = false; btn.textContent = 'Proposer l\'ajout au corpus'; if (msg) { msg.textContent = 'Erreur réseau, réessayez.'; } });
            });
        })();
        </script>
    {% endif %}
{% endblock %}
