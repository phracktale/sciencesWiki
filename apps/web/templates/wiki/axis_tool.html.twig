{% extends 'base.html.twig' %}
{% block title %}Évaluation critique — SciencesWiki{% endblock %}
{% block body %}
    <h1>Évaluation critique des études 🔬</h1>
    <p class="muted">Cherchez une étude par <strong>titre, mots-clés ou DOI</strong>. Selon le devis détecté, l'IA propose l'outil adapté : <strong>AXIS</strong> (études transversales) ou <strong>RoB 2</strong> (essais randomisés). <strong>Ce ne sont pas des notes</strong> — des signaux pour vous aider à juger, jamais un verdict.</p>

    <form class="ask" method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="max-width:560px; display:flex; gap:.5rem; align-items:flex-end; flex-wrap:wrap">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <div style="flex:1; min-width:280px">
            <label for="a-q">Titre, mots-clés ou DOI de l'étude</label>
            <input type="text" id="a-q" name="query" required value="{{ query }}" placeholder="ex. : essai randomisé metformine, ou 10.1136/bmj-…">
        </div>
        <button type="submit">Rechercher</button>
    </form>

    {% if error %}<p class="badge warn" style="margin-top:1rem">{{ error }}</p>{% endif %}

    {% if candidates is not empty and candidates is not null %}
        <h2 style="margin-top:1.4rem">Choisissez l'étude à évaluer</h2>
        <ul style="list-style:none; padding:0">
            {% for c in candidates %}
                <li class="card" style="margin:.5rem 0; display:flex; justify-content:space-between; gap:1rem; align-items:center; flex-wrap:wrap">
                    <div style="flex:1; min-width:260px">
                        <strong>{{ c.title }}</strong>
                        <div class="muted" style="font-size:.85rem">
                            {% if c.leadAuthor %}{{ c.leadAuthor }}{% if c.authors|length > 1 %} et al.{% endif %} · {% endif %}
                            {% if c.year %}{{ c.year }} · {% endif %}{{ c.venue }}
                            {% if c.citedByCount %} · 📈 {{ c.citedByCount }} cit.{% endif %}
                        </div>
                    </div>
                    {% if not c.doi %}
                        <span class="muted" style="font-size:.8rem">DOI manquant — non évaluable</span>
                    {% else %}
                        {% set st = toolStates[c.doi]|default(null) %}
                        {% set recoAxis = st and st.classified and st.axisApplicable %}
                        {% set recoRob2 = st and st.classified and st.rob2Applicable %}
                        <div style="text-align:right; min-width:220px">
                            {% if st is null or not st.classified %}
                                <div class="muted" style="font-size:.74rem; margin-bottom:.3rem">🔎 détection du type d'étude…</div>
                            {% else %}
                                <div class="muted" style="font-size:.74rem">Devis probable : <strong>{{ st.designLabel }}</strong></div>
                                {% for t in st.tools %}{% if not t.implemented %}<span class="badge" style="font-size:.7rem; background:#eef2ff; color:#3730a3; margin:.1rem 0 0 .2rem">{{ t.name }} · à venir</span>{% endif %}{% endfor %}
                            {% endif %}
                            <div style="margin-top:.35rem; display:flex; gap:.3rem; flex-wrap:wrap; justify-content:flex-end">
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="axis">
                                    <button type="submit"{% if not recoAxis %} style="background:#e2e8f0; color:#475569"{% endif %}>AXIS{% if recoAxis %} ✓{% endif %}</button>
                                </form>
                                <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" style="margin:0" class="js-axis-run">
                                    <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                                    <input type="hidden" name="doi" value="{{ c.doi }}">
                                    <input type="hidden" name="tool" value="rob2">
                                    <button type="submit"{% if not recoRob2 %} style="background:#e2e8f0; color:#475569"{% endif %}>RoB 2{% if recoRob2 %} ✓{% endif %}</button>
                                </form>
                            </div>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
        <p class="muted" style="font-size:.82rem">✓ = outil recommandé pour le devis détecté. L'analyse IA (~1 min) se lance <strong>en arrière-plan</strong> et le résultat <strong>s'affiche automatiquement</strong>.</p>
    {% endif %}

    {% if pending %}
        {% set toolName = pending.tool == 'rob2' ? 'RoB 2' : 'AXIS' %}
        <article class="card" id="axis-pending" data-doi="{{ pending.doi }}" data-tool="{{ pending.tool }}" data-status-url="{{ path('axis_status') }}" style="margin-top:1.2rem">
            <h2 style="margin-top:0">⏳ Évaluation {{ toolName }} en cours…</h2>
            {% if pending.publication %}<p><strong>{{ pending.publication.title }}</strong></p>{% endif %}
            <p class="muted">L'IA applique la grille {{ toolName }} (résumé + texte intégral) sur un serveur dédié. Cela prend <strong>~1 minute</strong>. Cette page se met à jour <strong>automatiquement</strong> ; vous pouvez aussi fermer et revenir plus tard : le résultat sera conservé.</p>
            <p class="muted" id="axis-pending-msg">🔄 Vérification automatique du résultat…</p>
            <form method="post" action="{{ path('axis_tool') }}" data-turbo="false" id="axis-pending-form" style="margin-top:.4rem">
                <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                <input type="hidden" name="doi" value="{{ pending.doi }}">
                <input type="hidden" name="tool" value="{{ pending.tool }}">
                <button type="submit">Rafraîchir maintenant</button>
            </form>
        </article>
        <script nonce="{{ csp_nonce.value }}">
        (function () {
            var box = document.getElementById('axis-pending');
            if (!box) { return; }
            var url = box.getAttribute('data-status-url') + '?tool=' + encodeURIComponent(box.getAttribute('data-tool')) + '&doi=' + encodeURIComponent(box.getAttribute('data-doi'));
            var msg = document.getElementById('axis-pending-msg');
            var form = document.getElementById('axis-pending-form');
            var tries = 0;
            var timer = setInterval(function () {
                tries++;
                fetch(url, { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (d.status === 'ready') { clearInterval(timer); form.submit(); }
                        else if (d.status === 'none') { clearInterval(timer); if (msg) { msg.textContent = '⚠️ Évaluation terminée sans résultat : cette étude n’est pas exploitable (ni résumé ni texte intégral accessible).'; } }
                        else if (tries > 75) { clearInterval(timer); if (msg) { msg.textContent = 'L’évaluation prend plus de temps que prévu. Cliquez « Rafraîchir maintenant ».'; } }
                    })
                    .catch(function () {});
            }, 4000);
        })();
        </script>
    {% endif %}

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        document.querySelectorAll('form.js-axis-run').forEach(function (f) {
            f.addEventListener('submit', function () {
                var b = f.querySelector('button');
                if (b) { b.disabled = true; b.textContent = '⏳…'; }
            });
        });
    })();
    </script>

    {% if result %}
        <article class="card" style="margin-top:1.2rem">
            <h2 style="margin-top:0">{{ result.publication.title }}</h2>
            <p class="muted" style="font-size:.85rem">
                {% if result.publication.year %}{{ result.publication.year }} · {% endif %}
                {% if result.publication.doi %}<a href="https://doi.org/{{ result.publication.doi }}" target="_blank" rel="noopener">{{ result.publication.doi }}</a>{% endif %}
            </p>

            {% if result.tool == 'rob2' %}
                {% set apColor = result.applicability == 'applicable' ? '#16a34a' : (result.applicability == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">RoB 2</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>

                {% if result.applicability == 'not_applicable' %}
                    <p class="muted">RoB 2 n'a été validé que pour les essais randomisés : la grille n'est <strong>pas</strong> appliquée à ce design (aucun résultat trompeur).</p>
                {% else %}
                    {% set ovColor = result.overall == 'low' ? '#16a34a' : (result.overall == 'high' ? '#dc2626' : '#f59e0b') %}
                    <p>Risque de biais global : <span class="badge" style="background:{{ ovColor }}22; color:{{ ovColor }}; font-weight:700">{{ result.overallLabel }}</span>
                       <span class="muted" style="margin-left:.4rem">(source : {{ result.sourceScope == 'abstract+fulltext' ? 'résumé + texte intégral' : 'résumé seul' }})</span></p>

                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}

                    <ul style="list-style:none; padding:0; margin:.6rem 0">
                        {% for d in result.domains %}
                            {% set dc = d.judgement == 'low' ? '#16a34a' : (d.judgement == 'high' ? '#dc2626' : '#f59e0b') %}
                            <li style="padding:.5rem 0; border-bottom:1px solid var(--line)">
                                <strong>{{ d.title }}</strong> — <span style="color:{{ dc }}; font-weight:600">{{ d.judgementLabel }}</span>
                                {% if d.rationale %}<div class="muted" style="font-size:.85rem; margin-top:.15rem">{{ d.rationale }}</div>{% endif %}
                                {% if d.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ d.quote }} »</blockquote>{% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            {% else %}
                {% set ap = result.applicability %}
                {% set apColor = ap == 'applicable' ? '#16a34a' : (ap == 'not_applicable' ? '#dc2626' : '#f59e0b') %}
                <p><span class="badge" style="background:#1e293b22; color:#1e293b; font-weight:700">AXIS</span>
                   <span class="badge" style="background:{{ apColor }}22; color:{{ apColor }}; font-weight:700; margin-left:.3rem">{{ result.applicabilityLabel }}</span>
                   {% if result.studyDesign %}<span class="muted" style="margin-left:.5rem">design détecté : {{ result.studyDesign }}</span>{% endif %}</p>

                {% if ap == 'not_applicable' %}
                    <p class="muted">AXIS n'a été validé que pour les études transversales : la grille n'est <strong>pas</strong> appliquée à ce design (aucun résultat trompeur).</p>
                {% else %}
                    {% set band = result.reliabilityBand %}
                    {% set bandLabel = {'high':'élevée','moderate':'modérée','low':'faible','insufficient':'insuffisante (texte trop limité)'} %}
                    <p>Fiabilité indicative : <strong>{{ bandLabel[band] ?? band }}</strong>
                       — {{ result.favorableCount }}/{{ result.assessableCount }} critères favorables
                       <span class="muted">(source : {{ result.sourceScope == 'abstract+fulltext' ? 'résumé + texte intégral' : 'résumé seul' }})</span></p>

                    {% if result.summary %}<p>{{ result.summary }}</p>{% endif %}

                    <details style="margin-top:.8rem">
                        <summary style="cursor:pointer; font-weight:600">Les 20 critères en détail</summary>
                        <ul style="list-style:none; padding:0; margin:.6rem 0">
                            {% for it in result.items %}
                                {% set icon = it.favorable ? '✅' : (it.answer == 'unclear' ? '❔' : '⚠️') %}
                                <li style="padding:.4rem 0; border-bottom:1px solid var(--line)">
                                    {{ icon }} <strong>{{ it.question }}</strong>
                                    <span class="muted">— {{ it.answerLabel }}</span>
                                    {% if it.quote %}<blockquote style="margin:.2rem 0 0 1.4rem; font-size:.85rem; color:#475569; border-left:2px solid var(--line); padding-left:.6rem">« {{ it.quote }} »</blockquote>{% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    </details>
                {% endif %}
            {% endif %}

            <p class="muted" style="font-size:.78rem; margin-top:1rem; border-top:1px dashed var(--line); padding-top:.6rem">{{ result.disclaimer }}</p>
        </article>
    {% endif %}
{% endblock %}
