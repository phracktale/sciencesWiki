<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}SciencesWiki{% endblock %}</title>
    <meta name="description" content="{% block description %}SciencesWiki — l'encyclopédie scientifique libre, gratuite et vulgarisée, adossée à des publications de recherche.{% endblock %}">
    {# Hotwire Turbo (auto-hébergé) : navigation instantanée (front + back-office). #}
    <script src="/js/turbo.min.js" defer></script>
    <style>
        :root { --accent:#1a5; --aca:#2563eb; --vul:#b45309; --bg:#fff; --line:#e5e7eb; --ink:#1f2937; }
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, sans-serif; max-width: 1200px; margin: 0 auto; padding: 1.5rem; color:var(--ink); line-height:1.6; }
        /* Accueil : 2 colonnes (principal + barre latérale). */
        .home-grid { display:grid; grid-template-columns: 1.7fr 1fr; gap:1.6rem; align-items:start; }
        @media (max-width:880px) { .home-grid { grid-template-columns:1fr; } }
        .side-block { border:1px solid var(--line); border-radius:14px; padding:1rem 1.1rem; margin-bottom:1.2rem; }
        .side-block h2 { margin:.1rem 0 .7rem; font-size:1.1rem; }
        /* Lanceurs de domaines colorés. */
        .domains { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:.8rem; }
        .domain-card { position:relative; overflow:hidden; display:block; border-radius:14px; padding:1.1rem; min-height:120px;
            color:#fff; text-decoration:none; box-shadow:0 1px 3px rgba(0,0,0,.12); transition:transform .18s ease, box-shadow .18s ease; }
        .domain-card::after { content:''; position:absolute; inset:0; background:rgba(0,0,0,.30); transition:background .18s ease; z-index:0; }
        .domain-card:hover { transform:scale(1.03); box-shadow:0 6px 18px rgba(0,0,0,.2); }
        .domain-card:hover::after { background:rgba(0,0,0,.40); }
        .domain-card > * { position:relative; z-index:1; }
        .domain-card .d-label { font-weight:800; font-size:1.05rem; text-shadow:0 1px 3px rgba(0,0,0,.4); }
        .domain-card .d-sub { font-size:.82rem; opacity:.95; text-shadow:0 1px 2px rgba(0,0,0,.4); }
        /* Onglets « Nous rejoindre ». */
        .join-tabs { display:flex; gap:.2rem; border-bottom:2px solid var(--line); margin-bottom:.8rem; flex-wrap:wrap; }
        .join-tabs button { background:none; border:none; border-bottom:3px solid transparent; margin-bottom:-2px; padding:.45rem .7rem; font:inherit; font-weight:600; color:#6b7280; cursor:pointer; }
        .join-tabs button[aria-selected="true"] { color:var(--accent); border-bottom-color:var(--accent); }
        .join-pane[hidden] { display:none; }
        .join-pane label { display:block; font-size:.82rem; font-weight:600; margin:.4rem 0 .15rem; }
        .join-pane input[type=text], .join-pane input[type=email], .join-pane textarea, .join-pane select { width:100%; padding:.45rem .6rem; border:1px solid #d1d5db; border-radius:8px; font:inherit; }
        .join-pane button[type=submit] { margin-top:.7rem; background:var(--accent); color:#fff; border:0; border-radius:8px; padding:.5rem 1rem; font:inherit; font-weight:600; cursor:pointer; }
        .stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
        .stat-grid .s { border:1px solid var(--line); border-radius:10px; padding:.6rem .7rem; }
        .stat-grid .s strong { font-size:1.3rem; display:block; }
        header { display:flex; align-items:baseline; gap:.6rem; flex-wrap:wrap; border-bottom:1px solid var(--line); padding-bottom:.8rem; margin-bottom:1.2rem; }
        header .brand { color: var(--accent); text-decoration: none; font-weight: 800; font-size:1.2rem; }
        header nav { margin-left:auto; display:flex; gap:1rem; font-size:.9rem; }
        h1 { margin: .3rem 0; font-size:1.7rem; }
        h2 { margin-top:1.6rem; }
        a { color: var(--aca); }
        .muted { color:#6b7280; }
        .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); gap:.6rem; }
        .card { display:block; border:1px solid var(--line); border-radius:10px; padding:.8rem; text-decoration:none; color:#111827; transition:border-color .15s; }
        .card:hover { border-color: var(--accent); }
        .crumbs { font-size:.9rem; }
        .crumbs a { color:#6b7280; text-decoration:none; }
        .crumbs a:hover { color:var(--accent); }
        .pill { display:inline-block; font-size:.72rem; padding:.12rem .55rem; border-radius:999px; background:#f1f5f9; color:#475569; border:1px solid var(--line); }
        .pill.author { background:#eef2ff; color:#3730a3; border-color:#e0e7ff; }
        .pill.node { background:#ecfdf5; color:#065f46; border-color:#d1fae5; }
        .badge { display:inline-block; font-size:.78rem; padding:.1rem .55rem; border-radius:999px; }
        .badge.ok { background:#dcfce7; color:#166534; }
        .badge.warn { background:#fef3c7; color:#92400e; }
        .qlist { list-style:none; padding:0; margin:0; }
        .qlist li { border:1px solid var(--line); border-radius:10px; padding:.7rem .9rem; margin:.5rem 0; }
        .qlist a.q-title { font-weight:600; text-decoration:none; color:#111827; font-size:1.05rem; }
        .qlist a.q-title:hover { color:var(--accent); }
        .qmeta { margin-top:.35rem; display:flex; gap:.45rem; align-items:center; flex-wrap:wrap; font-size:.8rem; }
        .qmeta time { color:#9ca3af; }
        .block-aca { border-left:3px solid var(--aca); padding-left:.9rem; }
        .block-vul { border-left:3px solid var(--vul); padding-left:.9rem; }
        .sources { font-size:.88rem; }
        .ask { border:1px solid var(--line); border-radius:12px; padding:1rem 1.1rem; margin:1.2rem 0; background:#fafafa; }
        .ask label { display:block; font-size:.85rem; font-weight:600; margin:.5rem 0 .2rem; }
        .ask input[type=text], .ask textarea { width:100%; padding:.55rem .7rem; border:1px solid #d1d5db; border-radius:8px; font:inherit; }
        .ask textarea { min-height:4.5rem; resize:vertical; }
        .ask button { margin-top:.8rem; background:var(--accent); color:#fff; border:0; border-radius:8px; padding:.6rem 1.1rem; font:inherit; font-weight:600; cursor:pointer; }
        .ask button:disabled { opacity:.5; cursor:not-allowed; }
        .loader { display:inline-block; width:1rem; height:1rem; border:2px solid #cbd5e1; border-top-color:var(--accent); border-radius:50%; animation:spin .8s linear infinite; vertical-align:-2px; }
        @keyframes spin { to { transform:rotate(360deg); } }
        #stream-out { white-space:pre-wrap; margin-top:1rem; padding:1rem; border:1px dashed #cbd5e1; border-radius:10px; min-height:2rem; }
        #stream-out h4 { color:var(--vul); margin:.6rem 0 .2rem; font-size:.95rem; text-transform:uppercase; letter-spacing:.04em; }
        .cartouche { display:flex; gap:.8rem; align-items:flex-start; border:1px solid var(--line); border-radius:12px; padding:.9rem 1rem; background:#fbfdff; margin:1rem 0; }
        .cartouche .avatar { width:42px; height:42px; border-radius:10px; background:linear-gradient(135deg,#1a5,#2563eb); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; flex:0 0 auto; }
        .cartouche .who { font-weight:700; }
        .cartouche .note { font-size:.85rem; color:#6b7280; }
        footer { margin-top:3rem; border-top:1px solid var(--line); padding-top:1rem; font-size:.8rem; color:#9ca3af; }
        footer a { color:#6b7280; }
        /* Menu back-office */
        .admin-nav { display:flex; flex-wrap:wrap; align-items:center; gap:.25rem; padding:.5rem .6rem; margin-bottom:1.4rem;
            background:#0f172a; border-radius:12px; }
        .admin-nav-brand { color:#fff; font-weight:700; font-size:.92rem; padding:.35rem .7rem; margin-right:.3rem; }
        .admin-nav a { color:#cbd5e1; text-decoration:none; font-size:.88rem; font-weight:600; padding:.4rem .8rem; border-radius:8px; transition:background .15s, color .15s; }
        .admin-nav a:hover { background:#1e293b; color:#fff; }
        .admin-nav a.active { background:var(--accent); color:#fff; }
        .admin-nav-logout { margin-left:auto; color:#fca5a5 !important; }
        .admin-nav-logout:hover { background:#7f1d1d !important; color:#fff !important; }
    </style>
</head>
<body>
    <header>
        <a class="brand" href="{{ path('home') }}">SciencesWiki</a>
        <span class="muted">— le savoir scientifique, libre et vulgarisé</span>
        <nav>
            <a href="{{ path('home') }}">Accueil</a>
            <a href="{{ path('project') }}">Le projet</a>
            <a href="{{ path('process') }}">Process</a>
        </nav>
    </header>
    <main>{% block body %}{% endblock %}</main>
    <footer>
        Contenu sous licence CC BY-SA 4.0 · vulgarisation sourcée, relue par un comité scientifique ·
        projet libre, gratuit et open source. <a href="{{ path('project') }}">En savoir plus</a>
    </footer>

    {% if admin_session.logged %}
        <div style="height:46px"></div>{# espace pour ne pas masquer le footer #}
        <div id="admin-bar" style="position:fixed; left:0; right:0; bottom:0; z-index:9999; background:#0f172a; color:#e2e8f0; font:13px/1.4 system-ui,sans-serif; display:flex; align-items:center; gap:.5rem; padding:.35rem .7rem; box-shadow:0 -2px 8px rgba(0,0,0,.2)">
            <strong style="background:#1a5; color:#fff; padding:.1rem .5rem; border-radius:5px">ADMIN</strong>
            <a href="{{ path('admin_dashboard') }}" style="color:#93c5fd">Tableau de bord</a>
            <a href="{{ path('admin_harvest') }}" style="color:#93c5fd">Moisson</a>
            <a href="{{ path('admin_activity') }}" style="color:#93c5fd">Journal</a>
            <a href="{{ path('admin_articles') }}" style="color:#93c5fd">Articles</a>
            <a href="{{ path('admin_settings') }}" style="color:#93c5fd">Paramètres</a>
            {% block admin_context %}{% endblock %}
            <span id="ab-harvest" style="margin-left:auto; display:flex; align-items:center; gap:.5rem">
                <span class="muted" style="color:#94a3b8">moisson :</span>
                <span id="ab-text" style="color:#cbd5e1">—</span>
                <span style="width:90px; height:7px; background:#334155; border-radius:4px; overflow:hidden"><span id="ab-bar" style="display:block; height:100%; width:0; background:#1a5"></span></span>
            </span>
            <a href="{{ path('admin_logout') }}" style="color:#fca5a5; margin-left:.4rem">quitter</a>
        </div>
        <script>
        (function () {
            var txt = document.getElementById('ab-text'), bar = document.getElementById('ab-bar');
            if (!txt) return;
            function poll() {
                fetch('/admin/harvest/status.json', { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) {
                        if (!d) return;
                        var running = (d.running || []).length, queued = d.queued || 0;
                        var run = (d.jobs || []).filter(function (j) { return j.status === 'running' && !j.stale; })[0];
                        if (run) {
                            txt.textContent = '⏳ ' + (run.label || run.rubric) + ' — ' + run.processed + ' traité(s)' + (queued ? ' · ' + queued + ' en file' : '');
                            bar.style.width = Math.min(100, Math.round(run.processed / 500 * 100)) + '%';
                        } else if (queued) {
                            txt.textContent = '⏳ ' + queued + ' moisson(s) en file';
                            bar.style.width = '5%';
                        } else {
                            txt.textContent = 'au repos'; bar.style.width = '0';
                        }
                    }).catch(function () {});
            }
            poll();
            var t = setInterval(poll, 5000);
            document.addEventListener('turbo:before-cache', function () { clearInterval(t); }, { once: true });
        })();
        </script>
    {% endif %}
</body>
</html>
