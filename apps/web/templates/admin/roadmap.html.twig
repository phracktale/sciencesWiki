{% extends 'base.html.twig' %}
{% block title %}Admin — Propositions de roadmap{% endblock %}
{% block body %}
    {% include 'admin/_nav.html.twig' %}
    {% for msg in app.flashes('success') %}<p class="badge ok" style="display:block; padding:.6rem 1rem; word-break:break-word">{{ msg }}</p>{% endfor %}
    {% for msg in app.flashes('error') %}<p class="badge warn" style="display:block; padding:.6rem 1rem">{{ msg }}</p>{% endfor %}

    <h1>Propositions de roadmap <span class="muted">({{ data.items|length }})</span></h1>

    {% set statusLabels = { 'new': 'Nouvelle', 'planned': 'Planifiée', 'declined': 'Écartée', 'done': 'Faite' } %}

    <p style="margin:.6rem 0">
        <a href="{{ path('admin_roadmap') }}" class="pill {{ status == '' ? 'author' }}">Toutes</a>
        {% for s in data.statuses %}
            <a href="{{ path('admin_roadmap', { status: s }) }}" class="pill {{ status == s ? 'author' }}">{{ statusLabels[s] ?? s }}</a>
        {% endfor %}
    </p>

    {% if data.items is empty %}
        <p class="muted">Aucune proposition.</p>
    {% else %}
        <div class="grid" style="grid-template-columns:1fr">
            {% for p in data.items %}
                <div class="card" style="display:block">
                    <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap">
                        <div style="flex:1 1 320px">
                            <strong>{{ p.name ?: 'Anonyme' }}</strong>
                            {% if p.status == 'new' %}<span class="badge warn">nouvelle</span>
                            {% elseif p.status == 'done' %}<span class="badge ok">faite</span>
                            {% else %}<span class="pill">{{ statusLabels[p.status] ?? p.status }}</span>{% endif %}
                            <br>
                            <span class="muted" style="font-size:.88rem">
                                {% if p.email %}✉️ <a href="mailto:{{ p.email }}">{{ p.email }}</a>{% else %}<em>sans e-mail</em>{% endif %}
                                · {{ p.createdAt|slice(0,10) }}
                            </span>
                            <p style="margin:.45rem 0 0; white-space:pre-wrap">{{ p.message }}</p>
                        </div>
                        <form method="post" action="{{ path('admin_roadmap_status', { id: p.id }) }}" style="display:flex; gap:.3rem; align-items:flex-start; flex-wrap:wrap">
                            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                            <select name="status" style="padding:.35rem; border:1px solid #d1d5db; border-radius:7px; font:inherit">
                                {% for s in data.statuses %}
                                    <option value="{{ s }}" {{ p.status == s ? 'selected' }}>{{ statusLabels[s] ?? s }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" style="background:var(--accent); color:#fff; border:0; border-radius:7px; padding:.35rem .8rem; cursor:pointer">Enregistrer</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
