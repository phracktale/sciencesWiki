{% extends 'base.html.twig' %}
{% block title %}Admin — Suivi de la moisson{% endblock %}
{% block body %}
    {% include 'admin/_nav.html.twig' %}

    <h1>Suivi de la moisson <span id="live" class="pill" style="font-size:.7rem; vertical-align:middle">● en direct</span></h1>
    <p class="muted">État de chaque moisson lancée depuis le back-office : en attente, en cours, terminée ou en erreur. Volume, durée et modèle d'embeddings indiqués. Les dépassements des limites OpenAlex sont signalés en rouge.</p>

    <style>
        .tabs { display:flex; gap:.3rem; border-bottom:2px solid var(--line); margin:1rem 0 1.2rem; flex-wrap:wrap }
        .tabs .tab-btn { background:none; border:none; border-bottom:3px solid transparent; margin-bottom:-2px;
            padding:.6rem 1rem; font:inherit; font-weight:600; color:#6b7280; cursor:pointer; text-decoration:none; border-radius:8px 8px 0 0 }
        .tabs .tab-btn[aria-selected="true"] { color:var(--accent); border-bottom-color:var(--accent) }
        .tabpane[hidden] { display:none }
        /* Panneaux Snapshot/Enrichissement = ÎLOTS CLAIRS (fond blanc, texte sombre),
           lisibles QUEL QUE SOIT le thème — y compris CRT (qui s'applique aussi en
           back-office) : on neutralise le phosphore et le glow à l'intérieur. */
        #pane-snapshot, #pane-enrichment { background:#fff; color:#1e293b; border:1px solid var(--line); border-radius:12px; padding:1.1rem 1.2rem }
        #pane-snapshot h2, #pane-snapshot h3, #pane-enrichment h2, #pane-enrichment h3 { color:#0f172a }
        body.theme-crt #pane-snapshot, body.theme-crt #pane-enrichment { background:#fff; color:#1e293b }
        body.theme-crt #pane-snapshot *, body.theme-crt #pane-enrichment * { text-shadow:none !important }
        body.theme-crt #pane-snapshot h2, body.theme-crt #pane-snapshot h3,
        body.theme-crt #pane-enrichment h2, body.theme-crt #pane-enrichment h3 { color:#0f172a }
        body.theme-crt #pane-snapshot .muted, body.theme-crt #pane-enrichment .muted { color:#64748b }
        body.theme-crt #pane-snapshot strong, body.theme-crt #pane-snapshot b,
        body.theme-crt #pane-enrichment strong, body.theme-crt #pane-enrichment b { color:#0f172a }
        body.theme-crt #pane-snapshot a, body.theme-crt #pane-enrichment a { color:#1d4ed8 }
        .enr-bar-track { height:12px; background:var(--line); border-radius:6px; overflow:hidden; margin:.3rem 0 }
        .enr-trend-down { color:#16a34a; font-weight:700 }
        .enr-trend-up { color:#dc2626; font-weight:700 }
        .snap-progress-line { color:#334155 !important }
        .snap-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:.8rem; margin:1rem 0 }
        .snap-stat { border:1px solid var(--line); border-radius:12px; padding:.9rem 1rem; background:#fafcff; color:#1e293b }
        .snap-stat .k { color:#475569; font-size:.8rem }
        .snap-stat .v { font-size:1.5rem; font-weight:700; line-height:1.2; color:#0f172a }
        .snap-art { border:1px solid var(--line); border-radius:10px; padding:.7rem .9rem; margin:.6rem 0; background:#fff; color:#1e293b }
        .snap-art h4 { margin:.1rem 0 .3rem; font-size:.98rem; color:#0f172a }
        .snap-art h4 a { color:#1d4ed8; text-decoration:underline }
        .snap-art .meta { font-size:.8rem; color:#475569; display:flex; gap:.5rem; flex-wrap:wrap; align-items:center }
        .snap-art .meta em { color:#475569; font-style:italic }
        .snap-art .ab { font-size:.86rem; color:#334155; margin:.4rem 0 0 }
        .snap-art .ab.muted { color:#94a3b8 }
        .snap-chip { display:inline-block; font-size:.72rem; font-weight:700; padding:.1rem .5rem; border-radius:999px; background:#eef2ff; color:#3730a3 }
    </style>

    <div class="tabs" role="tablist">
        <button role="tab" type="button" class="tab-btn" aria-selected="true" data-pane="pane-harvest">🛰️ Moisson API</button>
        <button role="tab" type="button" class="tab-btn" aria-selected="false" data-pane="pane-snapshot">📦 Snapshot OpenAlex</button>
        <button role="tab" type="button" class="tab-btn" aria-selected="false" data-pane="pane-enrichment">📈 Enrichissement</button>
        <a class="tab-btn" href="{{ path('admin_graph3d') }}" target="_blank" rel="noopener" style="margin-left:auto; color:var(--accent)">🌐 Visualiseur 3D ↗</a>
    </div>

    <section class="tabpane" id="pane-harvest">
    <div class="grid">
        <div class="card">
            <span class="muted">File d'attente (workers)</span><br>
            <strong id="queued" style="font-size:1.6rem">{{ status.queued ?? 0 }}</strong> moisson(s) en attente
        </div>
        <div class="card">
            <span class="muted">Requêtes OpenAlex aujourd'hui ({{ status.openalex.date ?? '' }})</span><br>
            <strong id="oa-used" style="font-size:1.6rem">{{ (status.openalex.used ?? 0)|number_format(0,',',' ') }}</strong>
            <span class="muted">/ <span id="oa-cap">{{ (status.openalex.perDay ?? 0)|number_format(0,',',' ') }}</span> (limite OpenAlex/jour) · <span id="oa-min">{{ status.openalex.perMinute ?? 0 }}</span>/min</span>
            <div style="margin-top:.4rem; height:8px; background:var(--line); border-radius:4px; overflow:hidden">
                <div id="oa-bar" style="height:100%; width:0%; background:var(--accent)"></div>
            </div>
            <p id="oa-warn" class="badge warn" hidden style="margin-top:.4rem">⛔ Limite quotidienne OpenAlex atteinte — réinitialisation à minuit UTC.</p>
        </div>
        <div class="card">
            <span class="muted">Crédit OpenAlex <span id="oa-key" class="pill" style="font-size:.65rem">sans clé API</span></span><br>
            <strong id="oa-credit-spent" style="font-size:1.6rem">—</strong>
            <span class="muted">$ dépensés / <span id="oa-credit-limit">—</span> $ accordés</span>
            <p class="muted" style="font-size:.78rem; margin:.3rem 0 0">Limite OpenAlex du jour : <strong id="oa-api-remaining">—</strong> / <span id="oa-api-limit">—</span> requêtes restantes. Polite pool gratuit (mailto), en-têtes lus <span id="oa-credit-at"></span>.</p>
        </div>
    </div>

    <h2>Moissons par rubrique</h2>
    <p style="display:flex; gap:.5rem; flex-wrap:wrap; margin:.2rem 0 .8rem">
        <button type="button" class="js-cleanup" data-mode="duplicates" style="font:inherit; cursor:pointer; padding:.3rem .7rem; border:1px solid #d1d5db; background:#fff; border-radius:6px">🧹 Purger les doublons</button>
        <button type="button" class="js-cleanup" data-mode="finished" style="font:inherit; cursor:pointer; padding:.3rem .7rem; border:1px solid #d1d5db; background:#fff; border-radius:6px">✅ Supprimer les terminées</button>
        <button type="button" class="js-cleanup" data-mode="all" style="font:inherit; cursor:pointer; padding:.3rem .7rem; border:1px solid #fca5a5; background:#fee2e2; color:#b91c1c; border-radius:6px">🗑 Tout réinitialiser</button>
        <span class="muted" style="font-size:.8rem; align-self:center">(n'affecte pas le corpus moissonné — uniquement le journal des moissons)</span>
    </p>
    <div id="action-status" hidden style="margin:.4rem 0; padding:.5rem .8rem; border-radius:8px; font-size:.9rem"></div>
    <table style="width:100%; border-collapse:collapse; font-size:.92rem">
        <thead>
            <tr style="text-align:left; border-bottom:2px solid var(--line)">
                <th style="padding:.5rem .4rem">Rubrique</th>
                <th style="padding:.5rem .4rem">État</th>
                <th style="padding:.5rem .4rem; width:22%">Progression</th>
                <th style="padding:.5rem .4rem; text-align:right">Nouveaux</th>
                <th style="padding:.5rem .4rem; text-align:right">Durée</th>
                <th style="padding:.5rem .4rem">Actions</th>
            </tr>
        </thead>
        <tbody id="jobs"><tr><td colspan="6" class="muted" style="padding:.7rem .4rem">Chargement…</td></tr></tbody>
    </table>
    <p class="muted" style="font-size:.82rem; margin-top:.6rem">Modèle d'embeddings utilisé : <strong id="emb-model">{{ status.embeddingModel ?? '—' }}</strong>.</p>
    </section>

    <section class="tabpane" id="pane-snapshot" hidden>
        <h2 style="margin-top:.4rem">Ingestion du snapshot OpenAlex <span id="snap-state" class="pill" style="font-size:.7rem">…</span></h2>
        <p class="muted">Chargement en masse du sous-ensemble pertinent du snapshot local (hors API). Embedding &amp; placement assurés en continu par le drain. La barre suit les fichiers (partitions <code>updated_date</code>) ; le compte à rebours est ré-estimé en direct.</p>

        <div id="snap-empty" class="muted" hidden style="padding:1rem">Aucune ingestion de snapshot enregistrée. Lancez <code>app:openalex:ingest-snapshot</code>.</div>

        <div id="snap-body" hidden>
            <div style="display:flex; align-items:baseline; gap:.6rem; flex-wrap:wrap; margin:.2rem 0 1rem; padding:.6rem .9rem; border:1px solid var(--line); border-radius:10px; background:#f5f8ff">
                <span style="font-size:.85rem; color:#475569">📚 Corpus total :</span>
                <strong id="snap-corpus" style="font-size:1.7rem; color:#1e293b">—</strong>
                <span class="muted" style="font-size:.8rem">publications en base (toutes sources confondues · ≈ estimation rapide). Le détail ci-dessous ne concerne que <strong>la passe d'ingestion en cours</strong>.</span>
            </div>
            <div style="margin:.6rem 0 .2rem; display:flex; justify-content:space-between; font-size:.85rem; color:#475569">
                <span><strong id="snap-pct">0%</strong> · fichier <span id="snap-files">0 / 0</span> <span id="snap-part" class="muted"></span></span>
                <span style="display:flex; gap:.6rem; align-items:center">
                    <span id="snap-stale" class="badge warn" hidden>⛔ ingestion arrêtée (aucune mise à jour depuis &gt;5 min)</span>
                    <form method="post" action="{{ path('admin_snapshot_relaunch_submit') }}" data-turbo="false" style="margin:0">
                        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                        <button type="submit" style="font-size:.78rem; padding:.25rem .6rem; cursor:pointer">↻ Relancer l'ingestion</button>
                    </form>
                </span>
            </div>
            <div style="height:14px; background:var(--line); border-radius:7px; overflow:hidden">
                <div id="snap-bar" style="height:100%; width:0%; background:var(--accent); transition:width .5s"></div>
            </div>

            <div class="snap-cards">
                <div class="snap-stat"><div class="k">Retenus (cette passe)</div><div class="v" id="snap-selected">—</div><div class="k" id="snap-projected">depuis la dernière reprise</div></div>
                <div class="snap-stat"><div class="k">Œuvres scannées (cette passe)</div><div class="v" id="snap-scanned">—</div><div class="k" id="snap-retention"></div></div>
                <div class="snap-stat"><div class="k">Temps écoulé (ce run)</div><div class="v" id="snap-elapsed">—</div><div class="k" id="snap-rate"></div></div>
                <div class="snap-stat"><div class="k">Durée restante estimée</div><div class="v" id="snap-eta">—</div><div class="k" id="snap-finish"></div></div>
            </div>

            <h3>Derniers articles intégrés <span class="muted" style="font-size:.8rem">(aperçu live)</span></h3>
            <div id="snap-arts"><p class="muted">Chargement…</p></div>
        </div>
    </section>

    <section class="tabpane" id="pane-enrichment" hidden>
        <h2 style="margin-top:.4rem">Enrichissement du corpus <span id="enr-state" class="pill" style="font-size:.7rem">…</span></h2>
        <p class="muted">Après l'ingestion (métadonnées + résumé), deux drains tournent en continu. <strong>Backlog</strong> = ce qu'il reste à traiter ; un backlog qui <span class="enr-trend-down">descend</span> = l'enrichissement rattrape, qui <span class="enr-trend-up">monte</span> = l'ingestion va plus vite que l'enrichissement. Débits recalculés en direct (fenêtre récente).</p>

        <h3>🧠 Embeddings &amp; placement <span class="muted" style="font-size:.8rem">— cron embed-drain (*/10)</span></h3>
        <div style="display:flex; justify-content:space-between; font-size:.85rem; color:#475569; margin-top:.4rem">
            <span>Couverture embeddings : <strong id="enr-embed-pct">—</strong></span>
            <span id="enr-embed-count" class="muted"></span>
        </div>
        <div class="enr-bar-track"><div id="enr-embed-bar" style="height:100%; width:0%; background:var(--accent); transition:width .5s"></div></div>
        <div class="snap-cards">
            <div class="snap-stat"><div class="k">Reste à embedder</div><div class="v" id="enr-embed-backlog">—</div><div class="k" id="enr-embed-trend">—</div></div>
            <div class="snap-stat"><div class="k">Reste à placer (arbre)</div><div class="v" id="enr-place-backlog">—</div><div class="k" id="enr-place-trend">—</div></div>
            <div class="snap-stat"><div class="k">📚 Corpus total</div><div class="v" id="enr-total">—</div><div class="k">publications en base · ≈ estimation rapide</div></div>
        </div>

        <h3 style="margin-top:1.2rem">📄 Plein texte <span class="muted" style="font-size:.8rem">— cron fulltext-drain (*/15) + GROBID</span></h3>
        <div class="snap-cards">
            <div class="snap-stat"><div class="k">File plein texte (à traiter)</div><div class="v" id="enr-ft-queue">—</div><div class="k" id="enr-ft-trend">—</div></div>
            <div class="snap-stat"><div class="k">Fragments indexés (chunks)</div><div class="v" id="enr-chunks">—</div><div class="k" id="enr-chunks-rate">—</div></div>
            <div class="snap-stat"><div class="k">Échecs (file failed)</div><div class="v" id="enr-failed">—</div><div class="k">re-tentés automatiquement</div></div>
        </div>
        <p class="muted" id="enr-updated" style="font-size:.8rem; margin-top:.6rem"></p>
    </section>

    <script type="application/json" id="bootstrap">{{ status|json_encode|raw }}</script>
    <script nonce="{{ csp_nonce.value }}">
    (function () {
        var tbody = document.getElementById('jobs');
        if (!tbody) return;
        var HARVEST = { maxPerRun: 500, capPerRubric: 0 }; // mis à jour par render() depuis l'API
        var CSRF = {{ admin_csrf.token|json_encode|raw }};

        function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }

        function fmtDate(s) {
            if (!s) return '—';
            var d = new Date(s.replace(' ', 'T'));
            return isNaN(d) ? esc(s) : d.toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
        }

        function fmtDuration(sec) {
            if (sec == null) return '—';
            if (sec < 60) return sec + ' s';
            var m = Math.floor(sec / 60), s = sec % 60;
            if (m < 60) return m + ' min ' + (s < 10 ? '0' : '') + s + ' s';
            return Math.floor(m / 60) + ' h ' + (m % 60) + ' min';
        }

        function isActive(job) { return (job.status === 'running' && !job.stale) || job.queued; }

        function badge(job) {
            if (job.stale) return '<span class="badge warn">⛔ interrompue (timeout)</span>';
            if (job.rateLimited) return '<span class="badge warn">⛔ limite OpenAlex</span>';
            if (job.queued && job.status !== 'running') return '<span class="badge warn"><span class="loader"></span> en file d\'attente</span>';
            switch (job.status) {
                case 'running': return '<span class="badge warn"><span class="loader"></span> en cours…</span>';
                case 'ok': return '<span class="badge ok">✅ terminée</span>';
                case 'partial': return job.errors > 0
                    ? '<span class="badge warn">⚠️ terminée (' + job.errors + ' erreur' + (job.errors > 1 ? 's' : '') + ')</span>'
                    : '<span class="badge warn" title="Moisson interrompue (recyclage ou redéploiement du worker) — reprend automatiquement au curseur à la prochaine exécution">⏸️ partielle (reprise auto)</span>';
                case 'failed': return '<span class="badge warn">⛔ échec</span>';
                default: return '<span class="muted">' + esc(job.status) + '</span>';
            }
        }

        function bar(job) {
            // Progression = cumul moissonné pour la rubrique / cible. Cible = plafond
            // configuré, sinon total dispo chez OpenAlex, sinon la taille de lot.
            var cumulative = job.cumulativeProcessed != null ? job.cumulativeProcessed : job.processed;
            // Cible = OBJECTIF DE MOISSON configuré (plafond/rubrique, sinon taille de
            // lot). Le total OpenAlex n'est PAS la cible : il s'affiche à part (≈ N).
            var target = HARVEST.capPerRubric > 0 ? HARVEST.capPerRubric : HARVEST.maxPerRun;
            var pct = target > 0 ? Math.min(100, Math.round((cumulative / target) * 100)) : 0;
            var running = job.status === 'running' && !job.stale;
            var color = job.stale ? '#9ca3af' : (running ? 'var(--accent)' : (job.errors > 0 || job.status === 'failed' ? '#dc2626' : '#16a34a'));
            var anim = running ? 'opacity:.85' : '';
            return '<div style="height:9px; background:var(--line); border-radius:5px; overflow:hidden" title="' + cumulative + ' / ' + target + '">' +
                   '<div style="height:100%; width:' + pct + '%; background:' + color + ';' + anim + '"></div></div>' +
                   '<span class="muted" style="font-size:.78rem">' + cumulative.toLocaleString('fr-FR') + ' / ' + target.toLocaleString('fr-FR') + ' (' + pct + '%)</span>';
        }

        function actions(job) {
            if (!job.nodeId) return '<span class="muted">—</span>';
            var active = isActive(job);
            // Relancer désactivé tant que la moisson est active (en cours / en file).
            var relaunch = '<button type="button" class="js-relaunch" data-node="' + job.nodeId + '"' +
                (active ? ' disabled title="Déjà en cours ou en file"' : '') +
                ' style="font:inherit; cursor:' + (active ? 'not-allowed' : 'pointer') + '; padding:.25rem .55rem; border:1px solid var(--accent); background:#fff; color:var(--accent); border-radius:6px; opacity:' + (active ? '.45' : '1') + '">↻ Relancer</button>';
            // Annuler : pertinent si en file/en cours.
            var cancel = active ? ' <button type="button" class="js-cancel" data-node="' + job.nodeId + '" style="font:inherit; cursor:pointer; padding:.25rem .55rem; border:1px solid #d1d5db; background:#fff; color:#6b7280; border-radius:6px">✕ Annuler</button>' : '';
            // Supprimer la ligne : toujours dispo (utile sur timeout/orpheline).
            var del = ' <button type="button" class="js-delete" data-node="' + job.nodeId + '" data-label="' + esc(job.label || job.rubric) + '" style="font:inherit; cursor:pointer; padding:.25rem .55rem; border:1px solid #fca5a5; background:#fff; color:#b91c1c; border-radius:6px">🗑</button>';
            return relaunch + cancel + del;
        }

        function row(job) {
            var label = esc(job.label || job.rubric || '—');
            var name = job.rubric ? '<a class="q-title" href="/admin/r/' + esc(job.rubric) + '">' + label + '</a>' : label;
            if (job.available != null) name += '<div class="muted" style="font-size:.74rem">≈ ' + job.available.toLocaleString('fr-FR') + ' articles chez OpenAlex</div>';
            var errLine = job.log ? '<div class="muted" style="font-size:.78rem; color:#b91c1c; margin-top:.2rem">' + esc(job.log) + '</div>' : '';
            var started = '<div class="muted" style="font-size:.74rem">' + fmtDate(job.startedAt) + '</div>';
            return '<tr style="border-bottom:1px solid var(--line)">' +
                '<td style="padding:.5rem .4rem">' + name + errLine + '</td>' +
                '<td style="padding:.5rem .4rem">' + badge(job) + '</td>' +
                '<td style="padding:.5rem .4rem">' + bar(job) + '</td>' +
                '<td style="padding:.5rem .4rem; text-align:right"><strong>' + job.created + '</strong></td>' +
                '<td style="padding:.5rem .4rem; text-align:right">' + fmtDuration(job.durationSeconds) + started + '</td>' +
                '<td style="padding:.5rem .4rem; white-space:nowrap">' + actions(job) + '</td>' +
                '</tr>';
        }

        function render(data) {
            if (data.harvest) HARVEST = data.harvest;
            var jobs = data.jobs || [];
            tbody.innerHTML = jobs.length ? jobs.map(row).join('') :
                '<tr><td colspan="6" class="muted" style="padding:.7rem .4rem">Aucune moisson lancée. Utilisez « Moissonner cette rubrique » depuis une rubrique.</td></tr>';

            document.getElementById('queued').textContent = data.queued || 0;
            if (data.embeddingModel) document.getElementById('emb-model').textContent = data.embeddingModel;

            var oa = data.openalex || {};
            document.getElementById('oa-used').textContent = (oa.used || 0).toLocaleString('fr-FR');
            document.getElementById('oa-cap').textContent = (oa.perDay || 0).toLocaleString('fr-FR');
            document.getElementById('oa-min').textContent = oa.perMinute || 0;
            var pct = oa.perDay ? Math.min(100, (oa.used / oa.perDay) * 100) : 0;
            var oaBar = document.getElementById('oa-bar');
            oaBar.style.width = pct + '%';
            oaBar.style.background = pct >= 90 ? '#dc2626' : (pct >= 70 ? '#f59e0b' : 'var(--accent)');
            document.getElementById('oa-warn').hidden = !oa.exhausted;

            var keyBadge = document.getElementById('oa-key');
            if (keyBadge) {
                keyBadge.textContent = oa.usesApiKey ? 'avec clé API' : 'sans clé API';
                keyBadge.style.background = oa.usesApiKey ? '#dcfce7' : '#f1f5f9';
                keyBadge.style.color = oa.usesApiKey ? '#166534' : '#475569';
            }
            document.getElementById('oa-credit-spent').textContent = oa.creditSpentUsd != null ? oa.creditSpentUsd.toFixed(4) : '—';
            document.getElementById('oa-credit-limit').textContent = oa.creditLimitUsd != null ? oa.creditLimitUsd.toFixed(2) : '—';
            document.getElementById('oa-api-remaining').textContent = oa.apiDailyRemaining != null ? oa.apiDailyRemaining.toLocaleString('fr-FR') : '—';
            document.getElementById('oa-api-limit').textContent = oa.apiDailyLimit != null ? oa.apiDailyLimit.toLocaleString('fr-FR') : '—';
            document.getElementById('oa-credit-at').textContent = oa.creditUpdatedAt ? '(' + fmtDate(oa.creditUpdatedAt) + ')' : '(jamais)';
        }

        var statusBox = document.getElementById('action-status');
        function showStatus(msg, ok) {
            statusBox.hidden = false;
            statusBox.textContent = msg;
            statusBox.style.background = ok ? '#dcfce7' : '#fee2e2';
            statusBox.style.color = ok ? '#166534' : '#b91c1c';
        }

        function op(kind, nodeId, btn, label) {
            btn.disabled = true;
            var prev = btn.innerHTML;
            btn.innerHTML = '<span class="loader"></span>';
            showStatus('Requête en cours…', true);
            fetch('/admin/harvest/' + kind, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nodeId: nodeId, _csrf: CSRF })
            })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, status: r.status, d: d }; }); })
            .then(function (res) {
                btn.innerHTML = prev; btn.disabled = false;
                // Un 409 (déjà en cours / en file) est informatif, pas une erreur bloquante.
                var ok = res.ok || res.status === 409;
                showStatus((label ? label + ' : ' : '') + (res.d.message || res.d.error || (res.ok ? 'OK' : 'Erreur ' + res.status)), ok);
                poll();
            })
            .catch(function (err) { btn.innerHTML = prev; btn.disabled = false; showStatus('Échec réseau : ' + err, false); });
        }

        tbody.addEventListener('click', function (e) {
            var r = e.target.closest('.js-relaunch'), c = e.target.closest('.js-cancel'), d = e.target.closest('.js-delete');
            if (r && !r.disabled) op('relaunch', +r.dataset.node, r, r.closest('tr').querySelector('.q-title') ? r.closest('tr').querySelector('.q-title').textContent : '');
            else if (c) op('cancel', +c.dataset.node, c, '');
            else if (d) { if (confirm('Supprimer la ligne « ' + d.dataset.label + ' » du suivi ? (le corpus n\'est pas touché)')) op('delete', +d.dataset.node, d, d.dataset.label); }
        });

        var confirmMsg = {
            duplicates: 'Purger les doublons (ne garder que la dernière moisson par rubrique) ?',
            finished: 'Supprimer toutes les lignes de moisson terminées / en erreur / orphelines ?',
            all: 'Tout réinitialiser : supprimer TOUTES les lignes de moisson ? (le corpus n\'est pas touché)'
        };
        Array.prototype.forEach.call(document.querySelectorAll('.js-cleanup'), function (btn) {
            btn.addEventListener('click', function () {
                var mode = btn.dataset.mode;
                if (!confirm(confirmMsg[mode])) return;
                btn.disabled = true;
                fetch('/admin/harvest/cleanup', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mode: mode, _csrf: CSRF })
                })
                .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                .then(function (res) { btn.disabled = false; alert(res.d.message || res.d.error || 'OK'); poll(); })
                .catch(function () { btn.disabled = false; });
            });
        });

        function poll() {
            fetch('/admin/harvest/status.json', { headers: { 'Accept': 'application/json' } })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (d) { if (d) render(d); })
                .catch(function () {});
        }

        try { render(JSON.parse(document.getElementById('bootstrap').textContent)); } catch (e) {}
        var timer = setInterval(poll, 4000);
        document.addEventListener('turbo:before-cache', function () { clearInterval(timer); }, { once: true });
    })();
    </script>

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        // --- Onglets ---
        var tabs = Array.prototype.slice.call(document.querySelectorAll('.tabs .tab-btn[data-pane]'));
        function show(pane) {
            tabs.forEach(function (t) {
                var on = t.dataset.pane === pane;
                t.setAttribute('aria-selected', on ? 'true' : 'false');
                var p = document.getElementById(t.dataset.pane);
                if (p) p.hidden = !on;
            });
            if (pane === 'pane-snapshot') { snapPoll(); startSnap(); } else { stopSnap(); }
            if (pane === 'pane-enrichment') { enrPoll(); startEnr(); } else { stopEnr(); }
        }
        tabs.forEach(function (t) {
            t.addEventListener('click', function () { show(t.dataset.pane); history.replaceState(null, '', '#' + t.dataset.pane); });
        });

        // --- Helpers ---
        function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
        function fmtDur(sec) {
            if (sec == null) return '—';
            sec = Math.max(0, Math.round(sec));
            var d = Math.floor(sec / 86400), h = Math.floor((sec % 86400) / 3600), m = Math.floor((sec % 3600) / 60), s = sec % 60;
            if (d > 0) return d + ' j ' + h + ' h';
            if (h > 0) return h + ' h ' + (m < 10 ? '0' : '') + m + ' min';
            if (m > 0) return m + ' min ' + (s < 10 ? '0' : '') + s + ' s';
            return s + ' s';
        }
        var OA = { gold:'#d4af37', green:'#16a34a', diamond:'#06b6d4', hybrid:'#f59e0b', bronze:'#b45309', closed:'#6b7280', unknown:'#94a3b8' };
        function oaChip(st) { var c = OA[st] || '#94a3b8'; return '<span class="snap-chip" style="background:' + c + '22; color:' + c + '">' + esc(st || 'inconnu') + '</span>'; }

        // --- État live (recalcul du chrono/compte à rebours entre deux polls) ---
        var live = null, recvAt = 0, snapTimer = null, tick = null;

        // Débit INSTANTANÉ : fenêtre glissante sur les derniers fichiers terminés
        // (on ignore tout l'historique → réagit aux accélérations/ralentissements).
        // On n'enregistre un point que quand done_files change (1 fichier ≈ qqs min).
        var snapEvents = [];           // {t, done, scanned}
        var SNAP_WINDOW = 7;           // ~6 intervalles inter-fichiers
        function pushEvent(d) {
            var last = snapEvents[snapEvents.length - 1];
            if (!last || last.done !== d.done_files || last.scanned !== d.scanned) {
                snapEvents.push({ t: Date.now(), done: d.done_files, scanned: d.scanned });
                if (snapEvents.length > SNAP_WINDOW) snapEvents.shift();
            }
        }
        function instantRate() {
            if (snapEvents.length < 2) return null;
            var a = snapEvents[0], b = snapEvents[snapEvents.length - 1];
            var dtSec = (b.t - a.t) / 1000;
            if (dtSec <= 0 || b.done <= a.done) return null;
            return {
                filesPerMin: (b.done - a.done) / (dtSec / 60),
                worksPerSec: (b.scanned - a.scanned) / dtSec,
                spanSec: dtSec,
            };
        }

        function paintTick() {
            if (!live) return;
            var dt = (Date.now() - recvAt) / 1000;
            document.getElementById('snap-elapsed').textContent = fmtDur((live.elapsed_run_sec || 0) + (live.finished ? 0 : dt));
            if (live.finished) { document.getElementById('snap-eta').textContent = 'terminé ✅'; return; }
            if (live.eta_sec == null) { document.getElementById('snap-eta').textContent = 'estimation…'; return; }
            document.getElementById('snap-eta').textContent = fmtDur(Math.max(0, live.eta_sec - dt));
        }

        function renderSnap(data) {
            var empty = document.getElementById('snap-empty'), body = document.getElementById('snap-body'), st = document.getElementById('snap-state');
            if (!data || !data.progress || !data.derived) {
                empty.hidden = false; body.hidden = true; st.textContent = 'inactif'; st.style.background = '#f1f5f9';
                return;
            }
            empty.hidden = true; body.hidden = false;
            var d = data.derived;
            // La commande écrit un battement de cœur toutes les ~30 s : l'API tranche
            // (d.stopped = >5 min sans MAJ). Fiable, sans faux positif sur un gros
            // fichier, et l'indicateur DISPARAÎT dès que l'ingestion repart.
            var isStale = !!d.stopped;
            st.textContent = d.finished ? 'terminé' : (isStale ? 'arrêté' : 'en cours');
            st.style.background = d.finished ? '#dcfce7' : (isStale ? '#fee2e2' : '#dbeafe');

            document.getElementById('snap-pct').textContent = d.percent + '%';
            document.getElementById('snap-files').textContent = (d.done_files || 0).toLocaleString('fr-FR') + ' / ' + (d.total_files || 0).toLocaleString('fr-FR');
            document.getElementById('snap-part').textContent = data.progress.partition ? '· ' + esc(data.progress.partition) : '';
            var bar = document.getElementById('snap-bar');
            bar.style.width = Math.min(100, d.percent) + '%';
            bar.style.background = d.finished ? '#16a34a' : (isStale ? '#dc2626' : 'var(--accent)');
            document.getElementById('snap-stale').hidden = !isStale;

            document.getElementById('snap-selected').textContent = (d.selected || 0).toLocaleString('fr-FR');
            if (data.corpus_total) document.getElementById('snap-corpus').textContent = '≈ ' + data.corpus_total.toLocaleString('fr-FR');
            document.getElementById('snap-scanned').textContent = (d.scanned || 0).toLocaleString('fr-FR');
            document.getElementById('snap-retention').textContent = 'rétention ' + (d.retention_pct || 0) + '%';

            // Débit + ETA INSTANTANÉS (fenêtre récente, on ignore l'historique lent).
            pushEvent(d);
            var inst = instantRate();
            var remaining = (d.remaining_files != null) ? d.remaining_files : Math.max(0, (d.total_files || 0) - (d.done_files || 0));
            var etaSec = d.finished ? 0 : (inst && inst.filesPerMin > 0 ? Math.round(remaining / inst.filesPerMin * 60) : null);

            document.getElementById('snap-rate').textContent = inst
                ? (Math.round(inst.worksPerSec).toLocaleString('fr-FR') + ' œuvres/s · ' + inst.filesPerMin.toFixed(2) + ' fichiers/min')
                : (d.finished ? '—' : 'mesure du débit en cours…');
            document.getElementById('snap-finish').textContent = (etaSec != null && !d.finished)
                ? 'fin ≈ ' + new Date(Date.now() + etaSec * 1000).toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' })
                : (d.finished ? '' : 'estimation en cours…');

            // Le compte à rebours s'appuie sur l'ETA INSTANTANÉ, pas la moyenne du run.
            live = { finished: d.finished, elapsed_run_sec: d.elapsed_run_sec, eta_sec: etaSec };
            recvAt = Date.now(); paintTick();

            var arts = document.getElementById('snap-arts');
            var rows = data.samples || [];
            arts.innerHTML = rows.length ? rows.map(function (a) {
                var title = a.url ? '<a href="' + esc(a.url) + '" target="_blank" rel="noopener">' + esc(a.title) + '</a>' : esc(a.title);
                var meta = [];
                if (a.domain) meta.push('<span class="snap-chip">' + esc(a.domain) + '</span>');
                meta.push(oaChip(a.oa_status));
                if (a.type) meta.push(esc(a.type));
                if (a.pub_date) meta.push('📅 ' + esc(a.pub_date));
                if (a.cited_by_count) meta.push('📈 ' + a.cited_by_count + ' cit.');
                if (a.language) meta.push('🗣 ' + esc(a.language));
                var authors = a.authors ? '<div class="meta"><em>' + esc(a.authors) + '</em></div>' : '';
                var ab = a.has_abstract ? '<p class="ab">' + esc(a.abstract) + (a.abstract && a.abstract.length >= 320 ? '…' : '') + '</p>' : '<p class="ab muted"><em>(pas de résumé)</em></p>';
                return '<div class="snap-art"><h4>' + title + '</h4><div class="meta">' + meta.join(' ') + '</div>' + authors + ab + '</div>';
            }).join('') : '<p class="muted">Aucune publication récente.</p>';
        }

        function snapPoll() {
            fetch('/admin/harvest/snapshot-status.json', { headers: { 'Accept': 'application/json' } })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (d) { if (d) renderSnap(d); })
                .catch(function () {});
        }
        function startSnap() { if (!snapTimer) snapTimer = setInterval(snapPoll, 5000); if (!tick) tick = setInterval(paintTick, 1000); }
        function stopSnap() { if (snapTimer) { clearInterval(snapTimer); snapTimer = null; } if (tick) { clearInterval(tick); tick = null; } }
        document.addEventListener('turbo:before-cache', stopSnap, { once: true });

        // ===================== Onglet Enrichissement =====================
        // Backlogs = EXACTS et temps réel (index partiels) → tendances fiables.
        // Totaux (corpus, chunks) = approximés (reltuples) → volume indicatif.
        var enrHist = [], enrTimer = null, ENR_WINDOW_MS = 5 * 60 * 1000;
        function enrRate(e) {
            var now = Date.now();
            enrHist.push({ t: now, eb: e.embed_backlog, pb: e.place_backlog, fq: e.fulltext_queue });
            var cut = now - ENR_WINDOW_MS;
            while (enrHist.length > 2 && enrHist[0].t < cut) enrHist.shift();
            if (enrHist.length < 2) return null;
            var a = enrHist[0], b = enrHist[enrHist.length - 1];
            var dtMin = (b.t - a.t) / 60000;
            if (dtMin <= 0) return null;
            return { eb: (b.eb - a.eb) / dtMin, pb: (b.pb - a.pb) / dtMin, fq: (b.fq - a.fq) / dtMin };
        }
        function trendBacklog(perMin) {
            if (perMin == null) return 'tendance…';
            var r = Math.round(perMin);
            if (r <= -1) return '<span class="enr-trend-down">↓ ' + Math.abs(r).toLocaleString('fr-FR') + '/min (résorption)</span>';
            if (r >= 1) return '<span class="enr-trend-up">↑ ' + r.toLocaleString('fr-FR') + '/min (accumulation)</span>';
            return 'stable';
        }
        function renderEnr(e) {
            if (!e) return;
            var st = document.getElementById('enr-state');
            st.textContent = 'en direct'; st.style.background = '#dbeafe';
            document.getElementById('enr-embed-pct').textContent = (e.embed_pct != null ? e.embed_pct : 0) + '%';
            document.getElementById('enr-embed-count').textContent = '≈ ' + (e.embedded || 0).toLocaleString('fr-FR') + ' / ' + (e.total_pub || 0).toLocaleString('fr-FR');
            document.getElementById('enr-embed-bar').style.width = Math.min(100, e.embed_pct || 0) + '%';
            document.getElementById('enr-embed-backlog').textContent = (e.embed_backlog || 0).toLocaleString('fr-FR');
            document.getElementById('enr-place-backlog').textContent = (e.place_backlog || 0).toLocaleString('fr-FR');
            document.getElementById('enr-total').textContent = '≈ ' + (e.total_pub || 0).toLocaleString('fr-FR');
            document.getElementById('enr-ft-queue').textContent = (e.fulltext_queue || 0).toLocaleString('fr-FR');
            document.getElementById('enr-chunks').textContent = '≈ ' + (e.total_chunks || 0).toLocaleString('fr-FR');
            document.getElementById('enr-chunks-rate').textContent = 'volume total (approx.)';
            document.getElementById('enr-failed').textContent = (e.failed_queue || 0).toLocaleString('fr-FR');
            var r = enrRate(e);
            document.getElementById('enr-embed-trend').innerHTML = r ? trendBacklog(r.eb) : 'tendance…';
            document.getElementById('enr-place-trend').innerHTML = r ? trendBacklog(r.pb) : 'tendance…';
            document.getElementById('enr-ft-trend').innerHTML = r ? trendBacklog(r.fq) : 'tendance…';
            document.getElementById('enr-updated').textContent = 'Mis à jour à ' + new Date().toLocaleTimeString('fr-FR') + ' · tendances sur ~5 min';
        }
        function enrPoll() {
            fetch('/admin/harvest/enrichment-status.json', { headers: { 'Accept': 'application/json' } })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (e) { if (e) renderEnr(e); })
                .catch(function () {});
        }
        function startEnr() { if (!enrTimer) enrTimer = setInterval(enrPoll, 10000); }
        function stopEnr() { if (enrTimer) { clearInterval(enrTimer); enrTimer = null; } }
        document.addEventListener('turbo:before-cache', stopEnr, { once: true });

        // Ouverture directe sur un onglet via #ancre.
        if (location.hash === '#pane-snapshot') { show('pane-snapshot'); }
        if (location.hash === '#pane-enrichment') { show('pane-enrichment'); }
    })();
    </script>
{% endblock %}
