{% extends 'base.html.twig' %}
{% block title %}Admin — Auteurs{% endblock %}
{% block body %}
    {% include 'admin/_nav.html.twig' %}
    <h1>Auteurs <span class="muted">({{ data.total|number_format(0,',',' ') }})</span></h1>

    {% import 'admin/_sort.html.twig' as s %}
    {% set baseParams = { q: data.query, sort: app.request.query.get('sort'), dir: app.request.query.get('dir') } %}
    <form method="get" action="{{ path('admin_authors') }}" style="display:flex; gap:.5rem; margin:1rem 0">
        <input type="text" name="q" value="{{ data.query }}" placeholder="Rechercher (nom ou ORCID)…"
               style="flex:1; padding:.55rem .7rem; border:1px solid #d1d5db; border-radius:8px; font:inherit">
        <button type="submit" style="background:var(--accent); color:#fff; border:0; border-radius:8px; padding:.55rem 1rem; cursor:pointer">Rechercher</button>
    </form>
    <p class="muted" style="font-size:.82rem">Cliquez sur un en-tête de colonne pour trier (asc/desc).</p>

    {% if data.items is empty %}
        <p class="muted">Aucun auteur.</p>
    {% else %}
        <table style="width:100%; border-collapse:collapse; font-size:.9rem">
            <thead>
                <tr style="text-align:left; border-bottom:2px solid var(--line)">
                    <th style="padding:.4rem">{{ s.th('Nom', 'nom', 'admin_authors', baseParams) }}</th><th>ORCID</th><th>Affiliation</th>
                    <th style="text-align:right">{{ s.th('Publications', 'publications', 'admin_authors', baseParams) }}</th>
                    <th style="text-align:right" title="Études rétractées (Retraction Watch)">{{ s.th('Rétractations', 'retractions', 'admin_authors', baseParams) }}</th>
                    <th style="text-align:right" title="Expressions de préoccupation">{{ s.th('EoC', 'eoc', 'admin_authors', baseParams) }}</th>
                </tr>
            </thead>
            <tbody>
                {% for a in data.items %}
                    <tr style="border-bottom:1px solid var(--line)">
                        <td style="padding:.4rem"><strong>{{ a.name }}</strong></td>
                        <td>{% if a.orcid %}<a href="https://orcid.org/{{ a.orcid }}" target="_blank" rel="noopener">{{ a.orcid }}</a>{% else %}<span class="muted">—</span>{% endif %}</td>
                        <td class="muted">{{ a.affiliation|default('—')|slice(0,70) }}</td>
                        <td style="text-align:right"><strong>{{ a.publications }}</strong></td>
                        <td style="text-align:right">{% if a.retractions > 0 %}<span class="badge warn" title="Études rétractées">{{ a.retractions }}</span>{% else %}<span class="muted">0</span>{% endif %}</td>
                        <td style="text-align:right">{% if a.eoc > 0 %}<span class="pill" style="background:#fef3c7" title="Expressions de préoccupation">{{ a.eoc }}</span>{% else %}<span class="muted">0</span>{% endif %}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <p style="margin-top:1rem; display:flex; gap:1rem; align-items:center">
            {% if data.page > 1 %}<a href="{{ path('admin_authors', baseParams|merge({ page: data.page - 1 })) }}">← Précédent</a>{% endif %}
            <span class="muted">Page {{ data.page }} / {{ data.pages }}</span>
            {% if data.page < data.pages %}<a href="{{ path('admin_authors', baseParams|merge({ page: data.page + 1 })) }}">Suivant →</a>{% endif %}
        </p>
    {% endif %}
{% endblock %}
