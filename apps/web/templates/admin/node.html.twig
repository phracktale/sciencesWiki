{% extends 'base.html.twig' %}
{% block title %}Admin — {{ node.label }}{% endblock %}
{% block body %}
    {% include 'admin/_nav.html.twig' %}
    <p class="crumbs">
        {% for c in node.breadcrumb ?? [] %}{% if not loop.first %} › {% endif %}{{ c.label }}{% endfor %}
        · <a href="/fr/{{ node.slug }}" target="_blank">voir public ↗</a>
    </p>
    {% for msg in app.flashes('success') %}<p class="badge ok">{{ msg }}</p>{% endfor %}
    {% for msg in app.flashes('error') %}<p class="badge warn">{{ msg }}</p>{% endfor %}

    <h1>{{ node.label }} <span class="muted">#{{ node.id }}</span></h1>

    <h2>Renommer / décrire</h2>
    <form class="ask" method="post" action="{{ path('admin_action') }}">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <input type="hidden" name="action" value="rename">
        <input type="hidden" name="id" value="{{ node.id }}">
        <input type="hidden" name="back" value="{{ node.slug }}">
        <label>Libellé</label>
        <input type="text" name="label" value="{{ node.label }}" required>
        <label>Description</label>
        <textarea name="description">{{ node.description }}</textarea>
        <button type="submit">Enregistrer</button>
    </form>

    <h2>Déplacer cette rubrique</h2>
    <form class="ask" method="post" action="{{ path('admin_action') }}">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <input type="hidden" name="action" value="move-node">
        <input type="hidden" name="id" value="{{ node.id }}">
        <input type="hidden" name="back" value="{{ node.slug }}">
        <label>Slug de la nouvelle rubrique parente</label>
        <input type="text" name="targetSlug" placeholder="ex. medicine" required>
        <button type="submit">Déplacer</button>
    </form>

    <h2>Ajouter une sous-rubrique</h2>
    <form class="ask" method="post" action="{{ path('admin_action') }}">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <input type="hidden" name="action" value="add-child">
        <input type="hidden" name="parentId" value="{{ node.id }}">
        <input type="hidden" name="back" value="{{ node.slug }}">
        <label>Libellé</label>
        <input type="text" name="label" required>
        <button type="submit">Ajouter</button>
    </form>

    {% if node.openalexConceptId %}
        <h2>Moissonner cette rubrique</h2>
        <p class="muted" style="font-size:.85rem">
            Récupère d'OpenAlex les publications de ce concept (incrémental, dédupliqué par DOI), puis calcule embeddings et placement.
            {% if node.lastHarvestedAt %}Dernière moisson : {{ node.lastHarvestedAt|date('d/m/Y H:i') }}.{% else %}Jamais moissonnée.{% endif %}
        </p>
        <form method="post" action="{{ path('admin_action') }}">
            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
            <input type="hidden" name="action" value="harvest">
            <input type="hidden" name="id" value="{{ node.id }}">
            <input type="hidden" name="back" value="{{ node.slug }}">
            <button type="submit">Moissonner (en arrière-plan)</button>
        </form>
        <div id="harvest-state" data-rubric="{{ node.slug }}" class="card" style="margin-top:.7rem" hidden></div>
        <p class="muted" style="font-size:.85rem; margin-top:.4rem">→ <a href="{{ path('admin_harvest') }}">Suivi de toutes les moissons</a> (progression et erreurs en direct).</p>
        <script>
        (function () {
            var box = document.getElementById('harvest-state');
            if (!box) return;
            var rubric = box.dataset.rubric;
            function refresh() {
                fetch('/admin/harvest/status.json', { headers: { 'Accept': 'application/json' } })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) {
                        if (!d) return;
                        var job = (d.jobs || []).filter(function (j) { return j.rubric === rubric; })[0];
                        if (!job) { box.hidden = true; return; }
                        box.hidden = false;
                        var label, color;
                        if (job.rateLimited) { label = '⛔ Limite OpenAlex atteinte — ' + (job.log || ''); color = '#b91c1c'; }
                        else if (job.stale) { label = '⚠️ Moisson interrompue (worker arrêté). Relancez-la.'; color = '#b45309'; }
                        else if (job.status === 'running') { label = '⏳ Moisson en cours — ' + job.processed + ' traité(s), ' + job.created + ' nouveau(x)'; color = 'var(--accent)'; }
                        else if (job.status === 'failed') { label = '⛔ Échec : ' + (job.log || 'erreur'); color = '#b91c1c'; }
                        else { label = (job.status === 'partial' ? '⚠️' : '✅') + ' Dernière moisson : ' + job.created + ' nouveau(x) sur ' + job.processed + ' traité(s)' + (job.errors ? ', ' + job.errors + ' erreur(s)' : ''); color = '#16a34a'; }
                        box.innerHTML = '<span style="color:' + color + '">' + label + '</span>';
                        if (job.status === 'running' && !job.stale) setTimeout(refresh, 4000);
                    }).catch(function () {});
            }
            refresh();
        })();
        </script>
    {% endif %}

    {% if node.openalexConceptId and node.level < 3 %}
        <h2>Greffer depuis OpenAlex</h2>
        <p class="muted" style="font-size:.85rem">Récupère d'OpenAlex les sous-rubriques de ce concept et ajoute celles qui manquent (concept : <a href="{{ node.openalexUrl }}" target="_blank">{{ node.openalexConceptId }}</a>).</p>
        <form method="post" action="{{ path('admin_action') }}">
            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
            <input type="hidden" name="action" value="graft">
            <input type="hidden" name="id" value="{{ node.id }}">
            <input type="hidden" name="back" value="{{ node.slug }}">
            <button type="submit">Ajouter les sous-rubriques OpenAlex manquantes</button>
        </form>
    {% endif %}

    {% if node.children is not empty %}
        <h2>Sous-rubriques</h2>
        <ul class="qlist">
            {% for c in node.children %}
                <li><a class="q-title" href="{{ path('admin_node', { slug: c.slug }) }}">{{ c.label }}</a></li>
            {% endfor %}
        </ul>
    {% endif %}

    <h2>Questions publiées ici</h2>
    {% if answers is empty %}
        <p class="muted">Aucune.</p>
    {% else %}
        <ul class="qlist">
            {% for a in answers %}
                <li>
                    <strong>{{ a.title }}</strong>
                    <div style="margin-top:.4rem; display:flex; gap:.4rem; align-items:center; flex-wrap:wrap">
                        <form method="post" action="{{ path('admin_action') }}" style="display:flex; gap:.4rem; align-items:center">
                            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                            <input type="hidden" name="action" value="move-question">
                            <input type="hidden" name="questionId" value="{{ a.questionId }}">
                            <input type="hidden" name="back" value="{{ node.slug }}">
                            <input type="text" name="targetSlug" placeholder="slug rubrique cible" required
                                   style="padding:.3rem .5rem; border:1px solid #d1d5db; border-radius:6px">
                            <button type="submit" style="padding:.3rem .7rem">Déplacer</button>
                        </form>
                        <form method="post" action="{{ path('admin_action') }}" onsubmit="return confirm('Supprimer définitivement cette question et ses réponses ?')" style="display:inline">
                            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
                            <input type="hidden" name="action" value="delete-question">
                            <input type="hidden" name="questionId" value="{{ a.questionId }}">
                            <input type="hidden" name="back" value="{{ node.slug }}">
                            <button type="submit" style="padding:.3rem .7rem; background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; border-radius:6px">🗑 Supprimer</button>
                        </form>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
