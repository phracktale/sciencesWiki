{% extends 'base.html.twig' %}
{% block title %}Admin — Tableau de bord{% endblock %}
{% block body %}
    <p class="crumbs"><strong>Administration</strong> ·
        <a href="{{ path('admin_articles') }}">Articles</a> ·
        <a href="{{ path('admin_harvest') }}">Moisson</a> ·
        <a href="{{ path('admin_activity') }}">Journal</a> ·
        <a href="{{ path('admin_users') }}">Utilisateurs</a> ·
        <a href="{{ path('admin_settings') }}">Paramètres IA</a> ·
        <a href="{{ path('admin_logout') }}">déconnexion</a></p>
    <h1>Tableau de bord</h1>
    {% for msg in app.flashes('success') %}<p class="badge ok">{{ msg }}</p>{% endfor %}
    {% for msg in app.flashes('error') %}<p class="badge warn">{{ msg }}</p>{% endfor %}

    <style>
        .tabs { display:flex; gap:.3rem; border-bottom:2px solid var(--line); margin:1rem 0 1.2rem }
        .tabs button { background:none; border:none; border-bottom:3px solid transparent; margin-bottom:-2px;
            padding:.6rem 1rem; font:inherit; font-weight:600; color:var(--muted, #6b7280); cursor:pointer }
        .tabs button[aria-selected="true"] { color:var(--accent); border-bottom-color:var(--accent) }
        .tabpane[hidden] { display:none }
        .twocol { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem }
        @media (max-width:720px) { .twocol { grid-template-columns:1fr } }
    </style>

    <div class="tabs" role="tablist">
        <button role="tab" aria-selected="true" data-pane="pane-corpus">Corpus &amp; progression</button>
        <button role="tab" aria-selected="false" data-pane="pane-domaines">Domaines</button>
        <button role="tab" aria-selected="false" data-pane="pane-systeme">Système &amp; base de données</button>
    </div>

    {# ===== Onglet 1 : Corpus + progression du corpus ===== #}
    <section class="tabpane" id="pane-corpus">
        {% set c = stats.corpus ?? {} %}
        <h2 style="margin-top:0">Corpus</h2>
        <div class="grid">
            <div class="card"><strong style="font-size:1.6rem">{{ (c.publications ?? 0)|number_format(0,',',' ') }}</strong><br><span class="muted">publications moissonnées</span></div>
            <div class="card"><strong style="font-size:1.6rem">{{ c.answers ?? 0 }}</strong><br><span class="muted">réponses publiées</span></div>
            <div class="card"><strong style="font-size:1.6rem">{{ c.questions ?? 0 }}</strong><br><span class="muted">questions</span></div>
            <div class="card"><strong style="font-size:1.6rem">{{ (c.treeNodes ?? 0)|number_format(0,',',' ') }}</strong><br><span class="muted">rubriques</span></div>
        </div>

        <h3>Publications par domaine</h3>
        <div class="grid">
            {% for r in c.roots ?? [] %}
                <a class="card" href="{{ path('admin_node', { slug: r.slug }) }}">{{ r.label }}<br><strong>{{ r.publications|number_format(0,',',' ') }}</strong> <span class="muted">publications</span></a>
            {% endfor %}
        </div>

        {% set hist = stats.history ?? [] %}
        {% if hist|length > 0 %}
            <h3>Progression du corpus</h3>
            {% set maxPub = max(hist|map(h => h.publications)) ?: 1 %}
            <div style="display:flex; align-items:flex-end; gap:4px; height:110px; border-bottom:1px solid var(--line); padding:.3rem 0">
                {% for h in hist %}
                    <div title="{{ h.day }} : {{ h.publications }} publications, {{ h.answers }} réponses"
                         style="flex:1; min-width:6px; background:var(--accent); border-radius:3px 3px 0 0; height:{{ (h.publications / maxPub * 100)|round }}%"></div>
                {% endfor %}
            </div>
            <p class="muted" style="font-size:.8rem">{{ hist|first.day }} → {{ hist|last.day }} ({{ hist|length }} jour(s)). Snapshot enregistré à chaque visite.</p>
        {% endif %}
    </section>

    {# ===== Onglet 2 : Domaines + Créer un domaine racine ===== #}
    <section class="tabpane" id="pane-domaines" hidden>
        <h2 style="margin-top:0">Aller à une rubrique (concept OpenAlex)</h2>
        <input type="text" id="oa-search" placeholder="Tapez un nom de rubrique…" autocomplete="off"
               style="width:100%; max-width:480px; padding:.55rem .7rem; border:1px solid #d1d5db; border-radius:8px; font:inherit">
        <ul id="oa-results" class="qlist"></ul>

        <h2>Domaines (édition)</h2>
        <div class="grid">
            {% for d in domains %}
                <a class="card" href="{{ path('admin_node', { slug: d.slug }) }}">{{ d.label }} <span class="muted">({{ d.childrenCount }})</span></a>
            {% endfor %}
        </div>

        <h2>Créer un domaine racine</h2>
        <form class="ask" method="post" action="{{ path('admin_action') }}">
            <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
            <input type="hidden" name="action" value="add-child">
            <label for="label">Libellé</label>
            <input type="text" id="label" name="label" required>
            <button type="submit">Créer</button>
        </form>
    </section>

    {# ===== Onglet 3 : Système + base de Données (2 colonnes) ===== #}
    <section class="tabpane" id="pane-systeme" hidden>
        {% set db = stats.database ?? {} %}
        {% set sys = stats.system ?? {} %}
        <div class="twocol">
            <div>
                <h2 style="margin-top:0">Système</h2>
                <ul class="qlist">
                    <li>OS : <strong>{{ sys.os ?? '—' }}</strong></li>
                    <li>PHP : <strong>{{ sys.php ?? '—' }}</strong></li>
                    <li>Serveur web : <strong>{{ sys.webServer ?? '—' }}</strong></li>
                    <li>Disque hôte Thor (partagé par tous les services) : <strong>{{ ((sys.diskUsedBytes ?? 0)/1073741824)|round(1) }} Go</strong> utilisés / {{ ((sys.diskTotalBytes ?? 0)/1073741824)|round(1) }} Go</li>
                    <li>Données SciencesWiki (base PostgreSQL : articles + embeddings) :
                        <strong>{% if (db.sizeBytes ?? 0) > 1073741824 %}{{ ((db.sizeBytes)/1073741824)|round(2) }} Go{% else %}{{ ((db.sizeBytes ?? 0)/1048576)|round(1) }} Mo{% endif %}</strong></li>
                </ul>
                <p class="muted" style="font-size:.8rem">Le disque hôte regroupe tous les conteneurs de Thor. SciencesWiki proprement dit ≈ la taille de sa base ci-dessus (+ ~quelques centaines de Mo d'images conteneurs).</p>
            </div>
            <div>
                <h2 style="margin-top:0">Base de données</h2>
                <p>{{ db.engine ?? '—' }} · version <strong>{{ db.version ?? '—' }}</strong><br>taille <strong>{{ ((db.sizeBytes ?? 0) / 1048576)|round }} Mo</strong></p>
                <ul class="qlist">
                    {% for name, n in db.tables ?? {} %}
                        <li style="display:flex; justify-content:space-between"><span>{{ name }}</span><strong>{{ n|number_format(0,',',' ') }}</strong></li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </section>

    <script>
    (function () {
        // Onglets (mémorise l'onglet actif dans l'URL #hash).
        var tabs = Array.prototype.slice.call(document.querySelectorAll('.tabs button'));
        function show(paneId) {
            tabs.forEach(function (t) {
                var sel = t.dataset.pane === paneId;
                t.setAttribute('aria-selected', sel ? 'true' : 'false');
                document.getElementById(t.dataset.pane).hidden = !sel;
            });
        }
        tabs.forEach(function (t) {
            t.addEventListener('click', function () { show(t.dataset.pane); history.replaceState(null, '', '#' + t.dataset.pane); });
        });
        if (location.hash && document.getElementById(location.hash.slice(1))) { show(location.hash.slice(1)); }

        // Recherche OpenAlex (autocomplete → navigation vers la rubrique).
        var inp = document.getElementById('oa-search'), out = document.getElementById('oa-results'), timer;
        if (inp) {
            inp.addEventListener('input', function () {
                clearTimeout(timer);
                var q = inp.value.trim();
                if (q.length < 2) { out.innerHTML = ''; return; }
                timer = setTimeout(function () {
                    fetch('/admin/openalex-search?q=' + encodeURIComponent(q))
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            out.innerHTML = (d.items || []).map(function (i) {
                                return '<li><a class="q-title" href="/admin/r/' + i.slug + '">' + i.label +
                                    '</a> <span class="muted">niv. ' + i.level + (i.openalexId ? ' · ' + i.openalexId : '') + '</span></li>';
                            }).join('');
                        });
                }, 250);
            });
        }
    })();
    </script>
{% endblock %}
