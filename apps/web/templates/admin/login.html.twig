{% extends 'base.html.twig' %}
{% block title %}Admin — Connexion{% endblock %}
{% block body %}
    <h1>Administration</h1>
    {% for msg in app.flashes('error') %}<p class="badge warn">{{ msg }}</p>{% endfor %}
    <form class="ask" method="post" action="{{ path('admin_login') }}" style="max-width:420px">
        <input type="hidden" name="_csrf" value="{{ admin_csrf.token }}">
        <label for="email">Email administrateur</label>
        <input type="text" id="email" name="email" required autocomplete="username">
        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="password" required autocomplete="current-password"
               style="width:100%; padding:.55rem .7rem; border:1px solid #d1d5db; border-radius:8px; font:inherit">
        <button type="submit">Se connecter</button>
    </form>
{% endblock %}
