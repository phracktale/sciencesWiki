{% extends 'base.html.twig' %}
{% block title %}Admin — Questions / Réponses{% endblock %}
{% block body %}
    {% include 'admin/_nav.html.twig' %}
    <h1>Questions / Réponses</h1>
    <p class="muted" style="font-size:.85rem">Édition et validation se font sur la page publique de chaque réponse.</p>

    {% if data.items is empty %}
        <p class="muted">Aucune question.</p>
    {% else %}
        <table style="width:100%; border-collapse:collapse; font-size:.9rem">
            <thead><tr style="text-align:left; border-bottom:2px solid var(--line)">
                <th style="padding:.4rem">Question</th><th>Rubrique</th><th>Auteur</th><th>Statut</th><th>Date</th>
            </tr></thead>
            <tbody>
            {% for q in data.items %}
                <tr style="border-bottom:1px solid var(--line)">
                    <td style="padding:.4rem"><a class="q-title" href="{{ path('answer', { id: q.answerId }) }}" target="_blank" rel="noopener">{{ q.title }}</a></td>
                    <td class="muted">{% if q.node.label is defined %}{{ q.node.label }}{% endif %}</td>
                    <td class="muted">{{ q.author }}</td>
                    <td>{% if q.status == 'valide' %}<span class="badge ok">validé</span>{% else %}<span class="badge warn">non relu</span>{% endif %}</td>
                    <td class="muted">{{ q.createdAt|date('d/m/Y') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div style="display:flex; gap:1rem; align-items:center; margin-top:.8rem; font-size:.85rem">
            {% if data.page > 1 %}<a href="{{ path('admin_questions', { page: data.page - 1 }) }}">← précédentes</a>{% endif %}
            <span class="muted">page {{ data.page }}</span>
            {% if data.hasMore %}<a href="{{ path('admin_questions', { page: data.page + 1 }) }}">suivantes →</a>{% endif %}
        </div>
    {% endif %}
{% endblock %}
