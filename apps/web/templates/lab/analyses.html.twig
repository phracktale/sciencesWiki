{% extends 'base.html.twig' %}

{% block title %}Analyses scientifiques — Labo{% endblock %}

{% block body %}
    <p style="margin:.2rem 0"><a href="{{ path('lab_hub') }}" class="muted">← Labo</a></p>
    <h1>🔬 Analyses scientifiques</h1>
    <p class="muted">Évaluation méthodologique composite d'une publication (AXIS, RoB 2, AMSTAR 2, MMAT…),
        ancrée sur le texte intégral. Le traitement n'est <strong>pas instantané</strong>.</p>

    <section class="side-block" style="margin-top:1rem">
        <form id="an-form" style="display:grid; gap:.6rem; max-width:640px">
            <label>Publication (identifiant interne ou DOI)
                <input type="text" id="an-ref" required placeholder="ex. 5307 ou 10.xxxx/xxxxx"
                       style="width:100%; padding:.5rem .7rem; border:1px solid var(--line); border-radius:8px; font:inherit">
            </label>
            <label>Plan d'étude
                <select id="an-design" style="width:100%; padding:.5rem .7rem; border:1px solid var(--line); border-radius:8px; font:inherit">
                    <option value="">Détection automatique</option>
                    <option value="cross_sectional">Transversale (AXIS)</option>
                    <option value="randomized_controlled_trial">Essai randomisé (RoB 2)</option>
                    <option value="cohort_prospective">Cohorte prospective</option>
                    <option value="cohort_retrospective">Cohorte rétrospective</option>
                    <option value="case_control">Cas-témoins</option>
                    <option value="systematic_review">Revue systématique (AMSTAR 2)</option>
                    <option value="meta_analysis">Méta-analyse (AMSTAR 2)</option>
                    <option value="mixed_methods">Méthodes mixtes (MMAT)</option>
                    <option value="diagnostic_accuracy">Diagnostique</option>
                    <option value="qualitative">Qualitative</option>
                </select>
            </label>
            <div><button type="submit" id="an-submit">Lancer l'analyse</button></div>
        </form>
        <p id="an-status" class="muted" style="margin:.8rem 0 0" hidden></p>
    </section>

    <section id="an-results" hidden style="margin-top:1rem"></section>

    <script nonce="{{ csp_nonce.value }}">
    (function () {
        var API = "{{ path('lab_analyses_proxy', {path: 'analyses'}) }}";
        var CAN_REVIEW = {{ canReview ? 'true' : 'false' }};
        var form = document.getElementById('an-form');
        var statusEl = document.getElementById('an-status');
        var resultsEl = document.getElementById('an-results');
        var submit = document.getElementById('an-submit');
        var timer = null, current = null;

        function setStatus(t) { statusEl.hidden = false; statusEl.textContent = t; }
        function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : s; return d.innerHTML; }
        function ansColor(a) {
            if (a === 'yes' || a === 'low') return '#16a34a';
            if (a === 'no' || a === 'high') return '#dc2626';
            if (a === 'unclear' || a === 'cant_tell') return '#94a3b8';
            return '#d97706';
        }

        function render(d) {
            current = d;
            var plan = d.plan || {}, fp = d.fingerprint || {}, crit = d.criteria || [];
            var validated = d.status === 'validated';
            var banner = validated
                ? '<p class="badge ok">✅ Analyse validée par ' + esc(d.validated_by) + '.</p>'
                : (d.human_review_required
                    ? '<p class="badge warn">⚠️ Générée par IA — validation humaine requise. Réponses non ancrées sur une citation vérifiée rétrogradées.</p>'
                    : '<p class="badge ok">✅ Ancrée sur les sources du texte intégral.</p>');

            var rows = crit.map(function (c) {
                var human = c.human_answer ? ' <span class="pill" style="font-size:.65rem">✎ ' + esc(c.reviewed_by || 'relu') + '</span>' : '';
                var edit = CAN_REVIEW ? '<button type="button" class="an-edit" data-cid="' + esc(c.criterion_id) + '" data-ans="' + esc(c.answer) + '" style="font:inherit; font-size:.7rem; cursor:pointer; border:1px solid var(--line); background:#fff; border-radius:5px; padding:0 .3rem">✏️</button>' : '';
                var vis = c.requires_visual_check ? ' <span class="pill" title="Dépend probablement d\'un tableau/figure non transcrit" style="font-size:.65rem">👁 à vérifier</span>' : '';
                var detail = '';
                if (c.expected) detail += '<div style="font-size:.78rem"><strong>Attendu :</strong> ' + esc(c.expected) + '</div>';
                if (c.evidence_found) detail += '<div style="font-size:.78rem"><strong>Trouvé :</strong> ' + esc(c.evidence_found) + '</div>';
                if (c.analysis) detail += '<div style="font-size:.78rem; font-style:italic; color:var(--muted,#475569)">' + esc(c.analysis) + '</div>';
                if (c.limitations) detail += '<div style="font-size:.75rem; color:#92400e"><strong>Limites :</strong> ' + esc(c.limitations) + '</div>';
                var vd = c.verdict ? '<div style="font-size:.72rem; color:' + ansColor(c.answer) + '">' + esc(c.verdict) + '</div>' : '';
                return '<tr>'
                    + '<td style="font-family:monospace; font-size:.75rem; white-space:nowrap; vertical-align:top">' + esc(c.criterion_id) + '</td>'
                    + '<td style="vertical-align:top"><span style="font-weight:700; text-transform:uppercase; font-size:.72rem; color:' + ansColor(c.answer) + '">' + esc(c.answer) + '</span>' + human + vis + vd + '</td>'
                    + '<td style="vertical-align:top">' + esc(c.question) + detail + '</td>'
                    + '<td style="text-align:center; font-size:.8rem; vertical-align:top">' + esc(c.confidence) + ' ' + edit + '</td>'
                    + '</tr>';
            }).join('');
            if (!rows) rows = '<tr><td colspan="4" class="muted">Aucun critère exécuté pour ce plan.</td></tr>';

            var validateBtn = (CAN_REVIEW && !validated)
                ? '<button type="button" class="an-validate">✅ Valider l\'analyse</button>' : '';

            resultsEl.innerHTML = banner
                + '<section class="side-block">'
                + '<div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:.5rem; align-items:center">'
                + '<h2 style="margin:0">Résultat</h2>'
                + '<span style="display:flex; gap:.4rem">' + validateBtn
                + '<a class="btn" href="' + API + '/' + d.id + '/pdf" target="_blank" rel="noopener">📄 PDF</a></span>'
                + '</div>'
                + '<p style="margin:.4rem 0"><strong>Plan :</strong> ' + esc(fp.design_label || d.primary_design || 'indéterminé')
                + ' · <strong>Référentiels :</strong> ' + esc((plan.primary_frameworks || []).concat(plan.reporting_frameworks || [], plan.risk_of_bias_tools || []).join(', ') || '—') + '</p>'
                + (d.applicable === false ? '<p class="badge warn">L\'IA juge AXIS non applicable à ce design (étape 0).</p>' : '')
                + (d.summary ? '<p style="margin:.4rem 0"><strong>Synthèse :</strong> ' + esc(d.summary) + '</p>' : '')
                + '<table style="width:100%; border-collapse:collapse; font-size:.9rem"><thead><tr>'
                + '<th style="text-align:left; border-bottom:2px solid var(--line); padding:.3rem">Critère</th>'
                + '<th style="text-align:left; border-bottom:2px solid var(--line); padding:.3rem">Réponse</th>'
                + '<th style="text-align:left; border-bottom:2px solid var(--line); padding:.3rem">Question / analyse</th>'
                + '<th style="border-bottom:2px solid var(--line); padding:.3rem">Conf.</th>'
                + '</tr></thead><tbody>' + rows + '</tbody></table>'
                + (CAN_REVIEW ? '<p class="muted" style="font-size:.78rem; margin:.5rem 0 0">Relecteur : ✏️ pour corriger une réponse (la correction est tracée et prime sur l\'IA).</p>' : '')
                + '</section>';
            resultsEl.hidden = false;
        }

        function reload(id) {
            fetch(API + '/' + id, { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
                .then(function (r) { return r.json(); }).then(render).catch(function () {});
        }

        function poll(id) {
            fetch(API + '/' + id, { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d.status === 'completed' || d.status === 'human_review_required' || d.status === 'validated') {
                        clearInterval(timer); setStatus('Terminé.'); submit.disabled = false; render(d);
                    } else if (d.status === 'failed') {
                        clearInterval(timer); setStatus('Échec de l\'analyse.'); submit.disabled = false;
                    } else {
                        setStatus('Statut : ' + d.status + '… (1 à 2 minutes)');
                    }
                })
                .catch(function () {});
        }

        // Actions relecteur (délégation).
        resultsEl.addEventListener('click', function (e) {
            var ed = e.target.closest('.an-edit');
            if (ed && current) {
                var cid = ed.getAttribute('data-cid');
                var ans = prompt('Réponse corrigée pour ' + cid + ' :', ed.getAttribute('data-ans'));
                if (ans == null) return;
                ans = ans.trim(); if (!ans) return;
                fetch(API + '/' + current.id + '/criteria/' + encodeURIComponent(cid), {
                    method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ answer: ans })
                }).then(function (r) { return r.json(); }).then(function () { reload(current.id); }).catch(function () {});
                return;
            }
            if (e.target.closest('.an-validate') && current) {
                if (!confirm('Valider cette analyse ?')) return;
                fetch(API + '/' + current.id + '/validate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
                    .then(function (r) { return r.json(); }).then(function () { reload(current.id); }).catch(function () {});
            }
        });

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            resultsEl.hidden = true; resultsEl.innerHTML = ''; submit.disabled = true;
            setStatus('Mise en file…');
            var body = { document_ref: document.getElementById('an-ref').value.trim() };
            var design = document.getElementById('an-design').value;
            if (design) body.study_design = design;
            fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body), cache: 'no-store' })
                .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                .then(function (res) {
                    if (!res.ok || !res.d.id) { setStatus('Erreur : ' + (res.d.error || 'requête invalide')); submit.disabled = false; return; }
                    setStatus('En file (id ' + res.d.id + ')…');
                    if (timer) clearInterval(timer);
                    timer = setInterval(function () { poll(res.d.id); }, 5000);
                    poll(res.d.id);
                })
                .catch(function () { setStatus('Erreur réseau.'); submit.disabled = false; });
        });

        // Ouverture directe d'une analyse du classeur (?id=...) : affiche le résultat
        // (et continue à interroger si elle est encore en cours).
        var qid = new URLSearchParams(window.location.search).get('id');
        if (qid) {
            setStatus('Chargement de l\'analyse…');
            if (timer) clearInterval(timer);
            timer = setInterval(function () { poll(qid); }, 5000);
            poll(qid);
        }
    })();
    </script>
{% endblock %}
