# Forcer les fins de ligne LF pour les fichiers exécutés/consommés sous Linux
# (sinon CRLF casse les shebangs d'entrypoint et les conf nginx/Caddy/PHP).
*.sh            text eol=lf
*.ini           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
Dockerfile      text eol=lf
Caddyfile       text eol=lf
.dockerignore   text eol=lf
*.conf          text eol=lf
