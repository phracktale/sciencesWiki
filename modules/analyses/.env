# Valeurs par défaut du module « analyses » (surchargées par .env.local ou l'env du
# conteneur). Ne jamais mettre de secret réel ici.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_in_env
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost

# --- Base PARTAGÉE SciencesWiki (mêmes identifiants que le cœur) ---
# Le module ne crée/migre QUE les tables analys_*.
DATABASE_URL="postgresql://sciences:__password__@marvin:5432/sciences?serverVersion=16&charset=utf8"

# --- Validation JWT : clé PUBLIQUE de SciencesWiki (montée en lecture seule) ---
# Le module NE signe jamais : pas de clé privée ni de passphrase.
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# --- LLM auto-hébergé (Ollama sur Marvin) — port SDK llm:generate ---
OLLAMA_URL=http://marvin:11434
# Modèle d'analyse (appraisal) et modèle léger d'empreinte (fingerprint).
ANALYS_MODEL=glm-5.2:cloud
ANALYS_EXTRACTOR_MODEL=glm-4.7-flash:latest
# Confiance de routage en-dessous de laquelle une validation humaine est requise.
ANALYS_HUMAN_REVIEW_THRESHOLD=0.75

# --- Notification de fin d'analyse (port mailer, optionnel) ---
# MAILER_DSN=null://null par défaut (no-op). Renseigner le relais SMTP pour activer.
ANALYS_MAIL_FROM=noreply@scienceswiki.eu
# URL publique du module (pour le lien dans l'e-mail). Vide = pas de lien.
MODULE_BASE_URL=

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###
