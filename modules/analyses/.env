# Valeurs par défaut du module « analyses » (surchargées par .env.local ou l'env du
# conteneur). Ne jamais mettre de secret réel ici.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_in_env
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost

# --- Base PARTAGÉE SciencesWiki (mêmes identifiants que le cœur) ---
# Le module ne crée/migre QUE les tables analys_*.
DATABASE_URL="postgresql://sciences:__password__@marvin:5432/sciences?serverVersion=16&charset=utf8"

# --- Validation JWT : clé PUBLIQUE de SciencesWiki (montée en lecture seule) ---
# Le module NE signe jamais : pas de clé privée ni de passphrase.
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# --- LLM auto-hébergé (Ollama sur Marvin) — port SDK llm:generate ---
OLLAMA_URL=http://marvin:11434
